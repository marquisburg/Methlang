// Mettle UI Demo — Documentation Browser
//
// Scans docs/ at runtime and renders Markdown in a readable native viewer.
//
// Build: examples\ui_demo\build.bat

import "std/ui";
import "std/io";
import "std/conv";
import "std/dir";
import "std/mem";

extern function Win_CreateCompatibleDC(hdc: int64) -> int64 = "CreateCompatibleDC";
extern function Win_CreateCompatibleBitmap(hdc: int64, width: int32, height: int32) -> int64 = "CreateCompatibleBitmap";
extern function Win_BitBlt(
  dest_dc: int64, x: int32, y: int32, width: int32, height: int32,
  src_dc: int64, x_src: int32, y_src: int32, rop: uint32) -> int32 = "BitBlt";
extern function Win_DeleteDC(hdc: int64) -> int32 = "DeleteDC";
extern function Win_InvalidateRect(hwnd: int64, rect: UiRect*, erase: int32) -> int32 = "InvalidateRect";

function UI_SRCCOPY() -> uint32 { return 0x00CC0020; }

function ID_STATUS() -> int32 { return 1003; }
function ID_THEME() -> int32 { return 1004; }
function ID_RELOAD() -> int32 { return 4001; }
function ID_ABOUT() -> int32 { return 4002; }
function ID_EXIT() -> int32 { return 4003; }

function VK_ESCAPE() -> uint32 { return 27; }
function VK_F5() -> uint32 { return 116; }

function SIDEBAR_ROW_HEIGHT() -> int32 { return 30; }

function DOC_BUF_SIZE() -> int32 { return 32768; }
function DISPLAY_BUF_SIZE() -> int32 { return 65536; }
function PATHS_BUF_SIZE() -> int32 { return 8192; }
function PATH_SLOT_SIZE() -> int32 { return 260; }
function MAX_DOCS() -> int32 { return 64; }

var g_main_window: int64 = 0;
var g_status_label: int64 = 0;
var g_theme_combo: int64 = 0;
var g_title_font: int64 = 0;
var g_h1_font: int64 = 0;
var g_h2_font: int64 = 0;
var g_h3_font: int64 = 0;
var g_body_font: int64 = 0;
var g_code_font: int64 = 0;
var g_small_font: int64 = 0;
var g_theme_index: int32 = 0;
var g_doc_count: int32 = 0;
var g_doc_len: int32 = 0;
var g_doc_lines: int32 = 0;
var g_display_lines: int32 = 0;
var g_selected_doc: int32 = -1;
var g_sidebar_scroll: int32 = 0;
var g_sidebar_hover: int32 = -1;
var g_viewer_scroll: int32 = 0;
var g_mouse_x: int32 = 0;
var g_mouse_y: int32 = 0;
var g_display_pos: int32 = 0;
var g_paths_blob: cstring = 0;
var g_path_slots: cstring = 0;
var g_doc_buf: cstring = 0;
var g_display_buf: cstring = 0;
var g_doc_root: cstring = 0;
var g_current_rel: cstring = 0;
var g_current_title: cstring = 0;
var g_content_left: int32 = 0;
var g_content_top: int32 = 0;
var g_content_right: int32 = 0;
var g_content_bottom: int32 = 0;
var g_sidebar_right: int32 = 0;
var g_viewer_left: int32 = 0;
var g_viewer_top: int32 = 0;
var g_viewer_right: int32 = 0;
var g_viewer_bottom: int32 = 0;
var g_viewer_content_height: int32 = 0;
var g_table_num_cols: int32 = 0;
var g_table_col_w0: int32 = 0;
var g_table_col_w1: int32 = 0;
var g_table_col_w2: int32 = 0;
var g_table_col_w3: int32 = 0;
var g_table_col_w4: int32 = 0;
var g_table_col_w5: int32 = 0;
var g_table_col_w6: int32 = 0;
var g_table_col_w7: int32 = 0;
var g_table_col_px0: int32 = 0;
var g_table_col_px1: int32 = 0;
var g_table_col_px2: int32 = 0;
var g_table_col_px3: int32 = 0;
var g_table_col_px4: int32 = 0;
var g_table_col_px5: int32 = 0;
var g_table_col_px6: int32 = 0;
var g_table_col_px7: int32 = 0;
var g_table_body_row: int32 = 0;
var g_table_stripe: int32 = 0;

function TABLE_CHAR_PX() -> int32 { return 9; }
function TABLE_COL_GAP() -> int32 { return 20; }

function accent_color() -> uint32 {
  if (g_theme_index == 1) { return ui_rgb(14, 116, 144); }
  if (g_theme_index == 2) { return ui_rgb(101, 84, 192); }
  return ui_rgb(37, 99, 235);
}

function accent_dark() -> uint32 {
  if (g_theme_index == 1) { return ui_rgb(21, 94, 117); }
  if (g_theme_index == 2) { return ui_rgb(79, 70, 155); }
  return ui_rgb(23, 75, 180);
}

function set_status(text: cstring) {
  ui_control_set_text(g_status_label, text);
}

function set_status_i64(pattern: string, value: int64) {
  var status: uint8[160];
  format_i64(&status[0], 160, pattern, value);
  ui_control_set_text(g_status_label, &status[0]);
}

function cstr_starts_with(text: cstring, prefix: cstring) -> int32 {
  var i: int32 = 0;
  while (prefix[i] != 0) {
    if (text[i] != prefix[i]) { return 0; }
    i = i + 1;
  }
  return 1;
}

function cstr_copy(dst: cstring, src: cstring, max_len: int32) -> int32 {
  var i: int32 = 0;
  while (i + 1 < max_len) {
    if (src[i] == 0) { break; }
    dst[i] = src[i];
    i = i + 1;
  }
  dst[i] = 0;
  return i;
}

function cstr_compare(a: cstring, b: cstring) -> int32 {
  var i: int32 = 0;
  while (a[i] != 0 || b[i] != 0) {
    if (a[i] < b[i]) { return -1; }
    if (a[i] > b[i]) { return 1; }
    i = i + 1;
  }
  return 0;
}

function path_join(base: cstring, suffix: cstring, out: cstring, out_len: int32) {
  var pos: int32 = cstr_copy(out, base, out_len);
  if (pos <= 0) { return; }
  if (pos + 1 >= out_len) { return; }
  if (out[pos - 1] != 47 && out[pos - 1] != 92) {
    out[pos] = 47;
    pos = pos + 1;
    out[pos] = 0;
  }
  cstr_copy(out + pos, suffix, out_len - pos);
}

function path_slot(index: int32) -> cstring {
  return g_path_slots + index * PATH_SLOT_SIZE();
}

function swap_path_slots(a: int32, b: int32) {
  var tmp: uint8[260];
  memcpy(&tmp[0], path_slot(a), PATH_SLOT_SIZE());
  memcpy(path_slot(a), path_slot(b), PATH_SLOT_SIZE());
  memcpy(path_slot(b), &tmp[0], PATH_SLOT_SIZE());
}

function sort_doc_paths() {
  var i: int32 = 0;
  while (i < g_doc_count - 1) {
    var j: int32 = i + 1;
    while (j < g_doc_count) {
      if (cstr_compare(path_slot(j), path_slot(i)) < 0) {
        swap_path_slots(i, j);
      }
      j = j + 1;
    }
    i = i + 1;
  }
}

function probe_docs_root(candidate: cstring) -> int32 {
  var marker: uint8[640];
  path_join(candidate, cstr("LANGUAGE.md"), &marker[0], 640);
  if (file_exists(&marker[0]) != 0) {
    cstr_copy(g_doc_root, candidate, 512);
    return 1;
  }
  return 0;
}

function resolve_docs_root() -> int32 {
  if (probe_docs_root(cstr("docs")) != 0) { return 1; }
  if (probe_docs_root(cstr("..\\docs")) != 0) { return 1; }
  if (probe_docs_root(cstr("..\\..\\docs")) != 0) { return 1; }

  var cwd: uint8[512];
  if (getcwd(&cwd[0], 512) == 0) {
    var joined: uint8[640];
    path_join(&cwd[0], cstr("docs"), &joined[0], 640);
    if (probe_docs_root(&joined[0]) != 0) { return 1; }
    path_join(&cwd[0], cstr("..\\docs"), &joined[0], 640);
    if (probe_docs_root(&joined[0]) != 0) { return 1; }
  }
  return 0;
}

function doc_label_from_path(rel: cstring, out: cstring, out_len: int32) {
  var pos: int32 = 0;
  var i: int32 = 0;
  while (rel[i] != 0 && pos + 1 < out_len) {
    if (rel[i] == 92) {
      out[pos] = 47;
    } else {
      out[pos] = rel[i];
    }
    pos = pos + 1;
    i = i + 1;
  }
  out[pos] = 0;
}

function scan_docs() -> int32 {
  memset(g_paths_blob, 0, PATHS_BUF_SIZE());
  g_doc_count = dir_list_md_files(g_doc_root, g_paths_blob, PATHS_BUF_SIZE(), MAX_DOCS());
  if (g_doc_count <= 0) { return 0; }

  var pos: int32 = 0;
  var i: int32 = 0;
  while (i < g_doc_count) {
    cstr_copy(path_slot(i), g_paths_blob + pos, PATH_SLOT_SIZE());
    while (g_paths_blob[pos] != 0) { pos = pos + 1; }
    pos = pos + 1;
    i = i + 1;
  }

  sort_doc_paths();
  g_sidebar_scroll = 0;
  g_sidebar_hover = -1;
  return g_doc_count;
}

function count_doc_lines() -> int32 {
  if (g_doc_len <= 0) { return 0; }
  var lines: int32 = 1;
  var i: int32 = 0;
  while (i < g_doc_len) {
    if (g_doc_buf[i] == 10) { lines = lines + 1; }
    i = i + 1;
  }
  return lines;
}

function doc_line_at(line_index: int32, out: cstring, out_len: int32) -> int32 {
  var current: int32 = 0;
  var pos: int32 = 0;
  var out_pos: int32 = 0;
  while (pos < g_doc_len && current < line_index) {
    if (g_doc_buf[pos] == 10) { current = current + 1; }
    pos = pos + 1;
  }
  while (pos < g_doc_len && g_doc_buf[pos] != 10 && g_doc_buf[pos] != 13) {
    if (out_pos + 1 < out_len) {
      out[out_pos] = g_doc_buf[pos];
      out_pos = out_pos + 1;
    }
    pos = pos + 1;
  }
  out[out_pos] = 0;
  return out_pos;
}

function cstr_len(text: cstring) -> int32 {
  var i: int32 = 0;
  while (text[i] != 0) {
    i = i + 1;
  }
  return i;
}

function display_reset() {
  g_display_pos = 0;
  memset(g_display_buf, 0, 1);
}

function display_null_terminate() {
  memset(g_display_buf + g_display_pos, 0, 1);
}

function display_append_char(ch: uint8) {
  if (g_display_pos + 1 >= DISPLAY_BUF_SIZE()) { return; }
  var byte: uint8[1];
  byte[0] = ch;
  memcpy(g_display_buf + g_display_pos, &byte[0], 1);
  g_display_pos = g_display_pos + 1;
  display_null_terminate();
}

function display_append_crlf() {
  display_append_char(10);
}

function display_append_text(text: cstring) {
  var i: int32 = 0;
  var byte: uint8[1];
  while (text[i] != 0 && g_display_pos + 1 < DISPLAY_BUF_SIZE()) {
    byte[0] = text[i];
    memcpy(g_display_buf + g_display_pos, &byte[0], 1);
    g_display_pos = g_display_pos + 1;
    i = i + 1;
  }
  display_null_terminate();
}

function display_strip_cr() {
  var read: int32 = 0;
  var write: int32 = 0;
  var byte: uint8[1];
  while (read < g_display_pos) {
    if (g_display_buf[read] == 13) {
      read = read + 1;
      continue;
    }
    if (write != read) {
      byte[0] = g_display_buf[read];
      memcpy(g_display_buf + write, &byte[0], 1);
    }
    write = write + 1;
    read = read + 1;
  }
  g_display_pos = write;
  display_null_terminate();
  g_display_lines = count_display_lines();
}

function md_heading_level(text: cstring) -> int32 {
  if (cstr_starts_with(text, cstr("### ")) != 0) { return 3; }
  if (cstr_starts_with(text, cstr("## ")) != 0) { return 2; }
  if (cstr_starts_with(text, cstr("# ")) != 0) { return 1; }
  return 0;
}

function md_strip_heading_prefix(text: cstring, out: cstring, out_len: int32) {
  var skip: int32 = 0;
  if (cstr_starts_with(text, cstr("### ")) != 0) { skip = 4; }
  else if (cstr_starts_with(text, cstr("## ")) != 0) { skip = 3; }
  else if (cstr_starts_with(text, cstr("# ")) != 0) { skip = 2; }
  else if (cstr_starts_with(text, cstr("- ")) != 0) { skip = 2; }
  else if (cstr_starts_with(text, cstr("* ")) != 0) { skip = 2; }
  else if (cstr_starts_with(text, cstr("> ")) != 0) { skip = 2; }
  var i: int32 = 0;
  while (text[skip + i] != 0 && i + 1 < out_len) {
    out[i] = text[skip + i];
    i = i + 1;
  }
  out[i] = 0;
}

function md_strip_inline(out: cstring) {
  var read: int32 = 0;
  var write: int32 = 0;
  while (out[read] != 0) {
    if (out[read] == 42 && out[read + 1] == 42) {
      read = read + 2;
      continue;
    }
    if (out[read] == 96) {
      read = read + 1;
      continue;
    }
    if (out[read] == 91) {
      while (out[read] != 0 && out[read] != 93) {
        out[write] = out[read];
        write = write + 1;
        read = read + 1;
      }
      if (out[read] == 93) { read = read + 1; }
      if (out[read] == 40) {
        while (out[read] != 0 && out[read] != 41) { read = read + 1; }
        if (out[read] == 41) { read = read + 1; }
      }
      continue;
    }
    out[write] = out[read];
    write = write + 1;
    read = read + 1;
  }
  out[write] = 0;
}

function md_is_ordered_item(text: cstring) -> int32 {
  if (text[0] < 48 || text[0] > 57) { return 0; }
  var i: int32 = 1;
  while (text[i] >= 48 && text[i] <= 57) { i = i + 1; }
  if (text[i] == 46 && text[i + 1] == 32) { return 1; }
  return 0;
}

function md_is_table_row(text: cstring) -> int32 {
  if (text[0] != 124) { return 0; }
  return 1;
}

function md_is_rule(text: cstring) -> int32 {
  if (text[0] == 45 && text[1] == 45 && text[2] == 45) { return 1; }
  if (text[0] == 42 && text[1] == 42 && text[2] == 42) { return 1; }
  return 0;
}

function format_markdown_for_viewer() {
  var line: int32 = 0;
  var in_code: int32 = 0;
  var line_buf: uint8[2048];
  var cleaned: uint8[2048];
  display_reset();

  while (line < g_doc_lines) {
    doc_line_at(line, &line_buf[0], 2048);

    if (cstr_starts_with(&line_buf[0], cstr("```")) != 0) {
      if (in_code != 0) {
        in_code = 0;
        display_append_crlf();
      } else {
        in_code = 1;
        display_append_crlf();
      }
      line = line + 1;
      continue;
    }

    if (in_code != 0) {
      display_append_text(cstr("    "));
      display_append_text(&line_buf[0]);
      display_append_crlf();
      line = line + 1;
      continue;
    }

    if (line_buf[0] == 0) {
      display_append_crlf();
      line = line + 1;
      continue;
    }

    if (md_is_rule(&line_buf[0]) != 0) {
      display_append_crlf();
      display_append_text(cstr("----------------------------------------"));
      display_append_crlf();
      line = line + 1;
      continue;
    }

    var level: int32 = md_heading_level(&line_buf[0]);
    if (level > 0) {
      display_append_crlf();
      md_strip_heading_prefix(&line_buf[0], &cleaned[0], 2048);
      md_strip_inline(&cleaned[0]);
      if (level == 1) {
        display_append_crlf();
        display_append_text(&cleaned[0]);
        display_append_crlf();
        display_append_crlf();
      } else {
        display_append_text(&cleaned[0]);
        display_append_crlf();
        display_append_crlf();
      }
      line = line + 1;
      continue;
    }

    if (cstr_starts_with(&line_buf[0], cstr("- ")) != 0 || cstr_starts_with(&line_buf[0], cstr("* ")) != 0) {
      md_strip_heading_prefix(&line_buf[0], &cleaned[0], 2048);
      md_strip_inline(&cleaned[0]);
      display_append_text(cstr("  - "));
      display_append_text(&cleaned[0]);
      display_append_crlf();
      line = line + 1;
      continue;
    }

    if (md_is_ordered_item(&line_buf[0]) != 0) {
      cstr_copy(&cleaned[0], &line_buf[0], 2048);
      md_strip_inline(&cleaned[0]);
      display_append_text(cstr("  "));
      display_append_text(&cleaned[0]);
      display_append_crlf();
      line = line + 1;
      continue;
    }

    if (md_is_table_row(&line_buf[0]) != 0) {
      cstr_copy(&cleaned[0], &line_buf[0], 2048);
      md_strip_inline(&cleaned[0]);
      display_append_text(&cleaned[0]);
      display_append_crlf();
      line = line + 1;
      continue;
    }

    if (cstr_starts_with(&line_buf[0], cstr("> ")) != 0) {
      md_strip_heading_prefix(&line_buf[0], &cleaned[0], 2048);
      md_strip_inline(&cleaned[0]);
      display_append_text(cstr("  > "));
      display_append_text(&cleaned[0]);
      display_append_crlf();
      line = line + 1;
      continue;
    }

    cstr_copy(&cleaned[0], &line_buf[0], 2048);
    md_strip_inline(&cleaned[0]);
    display_append_text(&cleaned[0]);
    display_append_crlf();
    line = line + 1;
  }
  g_display_lines = count_display_lines();
}

function count_display_lines() -> int32 {
  if (g_display_pos <= 0) { return 0; }
  var lines: int32 = 1;
  var i: int32 = 0;
  while (i < g_display_pos) {
    if (g_display_buf[i] == 10) { lines = lines + 1; }
    i = i + 1;
  }
  return lines;
}

function display_line_at(line_index: int32, out: cstring, out_len: int32) -> int32 {
  var current: int32 = 0;
  var pos: int32 = 0;
  var out_pos: int32 = 0;
  while (pos < g_display_pos && current < line_index) {
    if (g_display_buf[pos] == 10) { current = current + 1; }
    pos = pos + 1;
  }
  while (pos < g_display_pos && g_display_buf[pos] != 10 && g_display_buf[pos] != 13) {
    if (out_pos + 1 < out_len) {
      out[out_pos] = g_display_buf[pos];
      out_pos = out_pos + 1;
    }
    pos = pos + 1;
  }
  out[out_pos] = 0;
  return out_pos;
}

function copy_raw_doc_to_display() {
  display_reset();
  var i: int32 = 0;
  var byte: uint8[1];
  while (i < g_doc_len && g_display_pos + 1 < DISPLAY_BUF_SIZE()) {
    if (g_doc_buf[i] == 13) {
      i = i + 1;
      continue;
    }
    byte[0] = g_doc_buf[i];
    memcpy(g_display_buf + g_display_pos, &byte[0], 1);
    g_display_pos = g_display_pos + 1;
    i = i + 1;
  }
  display_null_terminate();
  g_display_lines = count_display_lines();
}

function update_current_title() {
  var line: uint8[512];
  var i: int32 = 0;
  while (i < g_doc_lines) {
    doc_line_at(i, &line[0], 512);
    if (md_heading_level(&line[0]) == 1) {
      md_strip_heading_prefix(&line[0], g_current_title, 128);
      md_strip_inline(g_current_title);
      return;
    }
    i = i + 1;
  }
  doc_label_from_path(g_current_rel, g_current_title, 128);
}

function load_doc(index: int32) -> int32 {
  if (index < 0) { return 0; }
  if (index >= g_doc_count) { return 0; }

  var rel: cstring = path_slot(index);
  var full: uint8[768];
  path_join(g_doc_root, rel, &full[0], 768);
  cstr_copy(g_current_rel, rel, 512);

  var fp: cstring = fopen(&full[0], cstr("rb"));
  if (fp == 0) {
    set_status(cstr("Could not open document."));
    display_reset();
    g_display_lines = 0;
    g_viewer_scroll = 0;
    invalidate_viewer_panel(g_main_window);
    return 0;
  }
  defer fclose(fp);

  var n: int64 = fread(g_doc_buf, 1, DOC_BUF_SIZE() - 1, fp);
  if (n <= 0) {
    g_doc_buf[0] = 0;
    g_doc_len = 0;
    display_reset();
    g_display_lines = 0;
    g_viewer_scroll = 0;
    g_viewer_content_height = 0;
    set_status(cstr("Document is empty."));
    invalidate_after_doc_load();
    return 0;
  }

  g_doc_len = (int32)n;
  memset(g_doc_buf + g_doc_len, 0, 1);
  g_doc_lines = count_doc_lines();
  g_selected_doc = index;
  g_viewer_scroll = 0;

  format_markdown_for_viewer();
  if (g_display_pos <= 0) {
    copy_raw_doc_to_display();
  }
  display_strip_cr();
  viewer_recompute_content_height();
  update_current_title();
  set_status(g_current_rel);
  invalidate_after_doc_load();
  return 1;
}

function select_doc_index(index: int32) {
  if (index < 0) { return; }
  if (index >= g_doc_count) { return; }
  load_doc(index);
}

function viewer_text_left() -> int32 { return g_viewer_left + 12; }
function viewer_text_right() -> int32 { return g_viewer_right - 24; }
function viewer_content_top() -> int32 { return g_viewer_top + 16; }
function viewer_content_bottom() -> int32 { return g_viewer_bottom - 16; }

function viewer_contains(x: int32, y: int32) -> int32 {
  if (x < g_viewer_left) { return 0; }
  if (x >= g_viewer_right) { return 0; }
  if (y < g_viewer_top) { return 0; }
  if (y >= g_viewer_bottom) { return 0; }
  return 1;
}

function VIEWER_KIND_BLANK() -> int32 { return 0; }
function VIEWER_KIND_H1() -> int32 { return 1; }
function VIEWER_KIND_H2() -> int32 { return 2; }
function VIEWER_KIND_H3() -> int32 { return 3; }
function VIEWER_KIND_BODY() -> int32 { return 4; }
function VIEWER_KIND_BULLET() -> int32 { return 5; }
function VIEWER_KIND_ORDERED() -> int32 { return 6; }
function VIEWER_KIND_CODE() -> int32 { return 7; }
function VIEWER_KIND_QUOTE() -> int32 { return 8; }
function VIEWER_KIND_RULE() -> int32 { return 9; }
function VIEWER_KIND_TABLE() -> int32 { return 10; }
function VIEWER_KIND_TABLE_SEP() -> int32 { return 11; }
function VIEWER_KIND_FENCE() -> int32 { return 12; }
function VIEWER_KIND_TABLE_HEADER() -> int32 { return 13; }

function TABLE_MAX_COLS() -> int32 { return 8; }

function table_col_width_get(index: int32) -> int32 {
  if (index == 0) { return g_table_col_w0; }
  if (index == 1) { return g_table_col_w1; }
  if (index == 2) { return g_table_col_w2; }
  if (index == 3) { return g_table_col_w3; }
  if (index == 4) { return g_table_col_w4; }
  if (index == 5) { return g_table_col_w5; }
  if (index == 6) { return g_table_col_w6; }
  if (index == 7) { return g_table_col_w7; }
  return 0;
}

function table_col_width_set(index: int32, width: int32) {
  if (index == 0) { g_table_col_w0 = width; return; }
  if (index == 1) { g_table_col_w1 = width; return; }
  if (index == 2) { g_table_col_w2 = width; return; }
  if (index == 3) { g_table_col_w3 = width; return; }
  if (index == 4) { g_table_col_w4 = width; return; }
  if (index == 5) { g_table_col_w5 = width; return; }
  if (index == 6) { g_table_col_w6 = width; return; }
  if (index == 7) { g_table_col_w7 = width; return; }
}

function table_col_px_get(index: int32) -> int32 {
  if (index == 0) { return g_table_col_px0; }
  if (index == 1) { return g_table_col_px1; }
  if (index == 2) { return g_table_col_px2; }
  if (index == 3) { return g_table_col_px3; }
  if (index == 4) { return g_table_col_px4; }
  if (index == 5) { return g_table_col_px5; }
  if (index == 6) { return g_table_col_px6; }
  if (index == 7) { return g_table_col_px7; }
  return 0;
}

function table_col_px_set(index: int32, x: int32) {
  if (index == 0) { g_table_col_px0 = x; return; }
  if (index == 1) { g_table_col_px1 = x; return; }
  if (index == 2) { g_table_col_px2 = x; return; }
  if (index == 3) { g_table_col_px3 = x; return; }
  if (index == 4) { g_table_col_px4 = x; return; }
  if (index == 5) { g_table_col_px5 = x; return; }
  if (index == 6) { g_table_col_px6 = x; return; }
  if (index == 7) { g_table_col_px7 = x; return; }
}

function table_col_width_reset() {
  g_table_num_cols = 0;
  g_table_col_w0 = 0;
  g_table_col_w1 = 0;
  g_table_col_w2 = 0;
  g_table_col_w3 = 0;
  g_table_col_w4 = 0;
  g_table_col_w5 = 0;
  g_table_col_w6 = 0;
  g_table_col_w7 = 0;
  g_table_col_px0 = 0;
  g_table_col_px1 = 0;
  g_table_col_px2 = 0;
  g_table_col_px3 = 0;
  g_table_col_px4 = 0;
  g_table_col_px5 = 0;
  g_table_col_px6 = 0;
  g_table_col_px7 = 0;
}

function table_cell_delim_pos(raw: cstring, start: int32) -> int32 {
  var pos: int32 = start;
  var in_tick: int32 = 0;
  while (raw[pos] != 0) {
    if (raw[pos] == 96) {
      in_tick = 1 - in_tick;
      pos = pos + 1;
      continue;
    }
    if (raw[pos] == 124 && in_tick == 0) {
      return pos;
    }
    pos = pos + 1;
  }
  return pos;
}

function table_row_cell_count(raw: cstring) -> int32 {
  if (raw[0] != 124) { return 0; }
  var count: int32 = 0;
  var pos: int32 = 0;
  while (raw[pos] != 0 && raw[pos] != 124) { pos = pos + 1; }
  while (raw[pos] == 124) {
    pos = pos + 1;
    while (raw[pos] == 32) { pos = pos + 1; }
    if (raw[pos] == 0) { break; }
    if (raw[pos] == 124) { continue; }
    count = count + 1;
    pos = table_cell_delim_pos(raw, pos);
  }
  return count;
}

function table_copy_cell(raw: cstring, cell_index: int32, out: cstring, out_len: int32) -> int32 {
  var pos: int32 = 0;
  var idx: int32 = 0;
  var write_pos: int32 = 0;

  while (raw[pos] != 0 && raw[pos] != 124) { pos = pos + 1; }
  while (raw[pos] == 124) {
    pos = pos + 1;
    while (raw[pos] == 32) { pos = pos + 1; }
    if (raw[pos] == 0) { break; }
    if (raw[pos] == 124) {
      if (idx == cell_index) {
        out[0] = 0;
        return 0;
      }
      idx = idx + 1;
      continue;
    }
    var start: int32 = pos;
    var end: int32 = table_cell_delim_pos(raw, pos) - 1;
    while (end >= start && raw[end] == 32) { end = end - 1; }
    if (idx == cell_index) {
      var i: int32 = start;
      var in_tick: int32 = 0;
      while (i <= end && write_pos + 1 < out_len) {
        if (raw[i] == 96) {
          in_tick = 1 - in_tick;
          i = i + 1;
          continue;
        }
        if (in_tick == 0 && raw[i] == 42 && raw[i + 1] == 42) {
          i = i + 2;
          continue;
        }
        out[write_pos] = raw[i];
        write_pos = write_pos + 1;
        i = i + 1;
      }
      out[write_pos] = 0;
      return write_pos;
    }
    idx = idx + 1;
    pos = table_cell_delim_pos(raw, pos);
  }
  out[0] = 0;
  return 0;
}

function table_measure_block(start_line: int32) {
  table_col_width_reset();
  var line: int32 = start_line;
  var raw: uint8[512];
  var cell: uint8[160];
  while (line < g_doc_lines) {
    doc_line_at(line, &raw[0], 512);
    if (md_is_table_sep(&raw[0]) != 0) {
      line = line + 1;
      continue;
    }
    if (md_is_table_row(&raw[0]) == 0) { break; }
    var cols: int32 = table_row_cell_count(&raw[0]);
    var i: int32 = 0;
    while (i < cols && i < TABLE_MAX_COLS()) {
      var w: int32 = table_copy_cell(&raw[0], i, &cell[0], 160);
      if (w > table_col_width_get(i)) {
        table_col_width_set(i, w);
      }
      i = i + 1;
    }
    if (cols > g_table_num_cols) { g_table_num_cols = cols; }
    line = line + 1;
  }
  table_compute_column_layout();
}

function table_compute_column_layout() {
  var x: int32 = viewer_text_left() + 8;
  var col: int32 = 0;
  while (col < g_table_num_cols && col < TABLE_MAX_COLS()) {
    table_col_px_set(col, x);
    var w: int32 = table_col_width_get(col);
    if (w < 1) { w = 1; }
    x = x + w * TABLE_CHAR_PX() + TABLE_COL_GAP();
    col = col + 1;
  }
}

function table_format_row(raw: cstring, out: cstring, out_len: int32) {
  out[0] = 0;
}

function viewer_classify_line_at(line: int32, raw: cstring, in_code: int32) -> int32 {
  var kind: int32 = viewer_classify_line(raw, in_code);
  if (kind == VIEWER_KIND_TABLE()) {
    if (line + 1 < g_doc_lines) {
      var next: uint8[512];
      doc_line_at(line + 1, &next[0], 512);
      if (md_is_table_sep(&next[0]) != 0) {
        return VIEWER_KIND_TABLE_HEADER();
      }
    }
  }
  return kind;
}

struct ViewerLineMetrics {
  height: int32;
  indent: int32;
  fg: uint32;
  bg: uint32;
  use_bg: int32;
  font: int64;
  wrap: int32;
  rule: int32;
  quote_bar: int32;
  underline: int32;
  top_pad: int32;
}

function md_is_table_sep(text: cstring) -> int32 {
  if (text[0] != 124) { return 0; }
  var i: int32 = 0;
  while (text[i] != 0) {
    var ch: uint8 = text[i];
    if (ch != 124 && ch != 45 && ch != 58 && ch != 32) { return 0; }
    i = i + 1;
  }
  return 1;
}

function viewer_classify_line(raw: cstring, in_code: int32) -> int32 {
  if (cstr_starts_with(raw, cstr("```")) != 0) {
    return VIEWER_KIND_FENCE();
  }
  if (in_code != 0) {
    return VIEWER_KIND_CODE();
  }
  if (raw[0] == 0) {
    return VIEWER_KIND_BLANK();
  }
  if (md_is_rule(raw) != 0) {
    return VIEWER_KIND_RULE();
  }
  var level: int32 = md_heading_level(raw);
  if (level == 1) { return VIEWER_KIND_H1(); }
  if (level == 2) { return VIEWER_KIND_H2(); }
  if (level == 3) { return VIEWER_KIND_H3(); }
  if (cstr_starts_with(raw, cstr("- ")) != 0 || cstr_starts_with(raw, cstr("* ")) != 0) {
    return VIEWER_KIND_BULLET();
  }
  if (md_is_ordered_item(raw) != 0) {
    return VIEWER_KIND_ORDERED();
  }
  if (cstr_starts_with(raw, cstr("> ")) != 0) {
    return VIEWER_KIND_QUOTE();
  }
  if (md_is_table_sep(raw) != 0) {
    return VIEWER_KIND_TABLE_SEP();
  }
  if (md_is_table_row(raw) != 0) {
    return VIEWER_KIND_TABLE();
  }
  return VIEWER_KIND_BODY();
}

function viewer_wrap_line_height(text: cstring, indent: int32) -> int32 {
  var width: int32 = viewer_text_right() - viewer_text_left() - indent;
  if (width < 120) { width = 120; }
  var len: int32 = cstr_len(text);
  if (len <= 0) { return 10; }
  var chars_per_line: int32 = width / 8;
  if (chars_per_line < 24) { chars_per_line = 24; }
  var rows: int32 = (len + chars_per_line - 1) / chars_per_line;
  if (rows < 1) { rows = 1; }
  return rows * 22 + 6;
}

function viewer_format_line(raw: cstring, kind: int32, out: cstring, out_len: int32) {
  var cleaned: uint8[512];
  if (kind == VIEWER_KIND_BLANK() || kind == VIEWER_KIND_FENCE() || kind == VIEWER_KIND_RULE()) {
    out[0] = 0;
    return;
  }
  if (kind == VIEWER_KIND_TABLE_SEP()) {
    out[0] = 0;
    return;
  }
  if (kind == VIEWER_KIND_TABLE() || kind == VIEWER_KIND_TABLE_HEADER()) {
    table_format_row(raw, out, out_len);
    return;
  }
  if (kind == VIEWER_KIND_CODE()) {
    utf8_normalize_ascii(raw, out, out_len);
    return;
  }
  if (kind == VIEWER_KIND_H1() || kind == VIEWER_KIND_H2() || kind == VIEWER_KIND_H3()) {
    md_strip_heading_prefix(raw, &cleaned[0], 512);
  } else if (kind == VIEWER_KIND_BULLET()) {
    md_strip_heading_prefix(raw, &cleaned[0], 512);
  } else if (kind == VIEWER_KIND_QUOTE()) {
    md_strip_heading_prefix(raw, &cleaned[0], 512);
  } else {
    cstr_copy(&cleaned[0], raw, 512);
  }
  md_strip_inline(&cleaned[0]);
  utf8_normalize_ascii(&cleaned[0], out, out_len);
}

function viewer_line_metrics(kind: int32, text: cstring, theme: UiTheme) -> ViewerLineMetrics {
  var m: ViewerLineMetrics;
  m.indent = 0;
  m.use_bg = 0;
  m.bg = ui_rgb(255, 255, 255);
  m.wrap = 0;
  m.rule = 0;
  m.quote_bar = 0;
  m.underline = 0;
  m.top_pad = 0;
  m.font = g_body_font;
  m.fg = theme.text;

  if (kind == VIEWER_KIND_BLANK()) {
    m.height = 8;
    return m;
  }
  if (kind == VIEWER_KIND_FENCE()) {
    m.height = 10;
    return m;
  }
  if (kind == VIEWER_KIND_RULE()) {
    m.height = 18;
    m.rule = 1;
    return m;
  }
  if (kind == VIEWER_KIND_TABLE_SEP()) {
    m.height = 6;
    return m;
  }
  if (kind == VIEWER_KIND_H1()) {
    m.height = 40;
    m.top_pad = 10;
    m.font = g_h1_font;
    m.fg = accent_color();
    m.underline = 1;
    return m;
  }
  if (kind == VIEWER_KIND_H2()) {
    m.height = 34;
    m.top_pad = 8;
    m.font = g_h2_font;
    m.fg = accent_dark();
    return m;
  }
  if (kind == VIEWER_KIND_H3()) {
    m.height = 28;
    m.top_pad = 6;
    m.font = g_h3_font;
    m.fg = theme.text;
    return m;
  }
  if (kind == VIEWER_KIND_CODE()) {
    m.height = 24;
    m.indent = 8;
    m.font = g_code_font;
    m.fg = ui_rgb(30, 41, 59);
    m.bg = ui_rgb(243, 244, 246);
    m.use_bg = 1;
    return m;
  }
  if (kind == VIEWER_KIND_QUOTE()) {
    m.height = viewer_wrap_line_height(text, 22);
    m.indent = 22;
    m.quote_bar = 1;
    m.font = g_body_font;
    m.fg = theme.muted_text;
    m.wrap = 1;
    return m;
  }
  if (kind == VIEWER_KIND_BULLET()) {
    m.height = viewer_wrap_line_height(text, 20);
    m.indent = 20;
    m.font = g_body_font;
    m.fg = theme.text;
    m.wrap = 1;
    return m;
  }
  if (kind == VIEWER_KIND_ORDERED()) {
    m.height = viewer_wrap_line_height(text, 12);
    m.indent = 12;
    m.font = g_body_font;
    m.fg = theme.text;
    m.wrap = 1;
    return m;
  }
  if (kind == VIEWER_KIND_TABLE()) {
    m.height = 24;
    m.indent = 8;
    m.font = g_body_font;
    m.fg = ui_rgb(51, 65, 85);
    if (g_table_stripe != 0) {
      m.bg = ui_rgb(248, 250, 252);
    } else {
      m.bg = ui_rgb(255, 255, 255);
    }
    m.use_bg = 1;
    return m;
  }
  if (kind == VIEWER_KIND_TABLE_HEADER()) {
    m.height = 26;
    m.indent = 8;
    m.font = g_body_font;
    m.fg = ui_rgb(255, 255, 255);
    m.bg = accent_color();
    m.use_bg = 1;
    return m;
  }

  m.height = viewer_wrap_line_height(text, 0);
  m.font = g_body_font;
  m.fg = theme.text;
  m.wrap = 1;
  return m;
}

function viewer_total_content_height() -> int32 {
  var total: int32 = 0;
  var line: int32 = 0;
  var in_code: int32 = 0;
  var in_table: int32 = 0;
  var raw: uint8[512];
  var text: uint8[512];
  while (line < g_doc_lines) {
    doc_line_at(line, &raw[0], 512);
    var kind: int32 = viewer_classify_line_at(line, &raw[0], in_code);
    if (kind == VIEWER_KIND_FENCE()) {
      in_code = 1 - in_code;
    }
    if (kind == VIEWER_KIND_TABLE() || kind == VIEWER_KIND_TABLE_HEADER()) {
      if (in_table == 0) {
        table_measure_block(line);
        g_table_body_row = 0;
        in_table = 1;
      }
    } else if (kind != VIEWER_KIND_TABLE_SEP()) {
      in_table = 0;
    }
    if (kind == VIEWER_KIND_TABLE()) {
      g_table_stripe = g_table_body_row % 2;
      g_table_body_row = g_table_body_row + 1;
    }
    viewer_format_line(&raw[0], kind, &text[0], 512);
    var m: ViewerLineMetrics = viewer_line_metrics(kind, &text[0], ui_default_theme());
    total = total + m.top_pad + m.height;
    line = line + 1;
  }
  return total;
}

function viewer_max_scroll() -> int32 {
  var view_h: int32 = viewer_content_bottom() - viewer_content_top();
  var est_h: int32 = g_viewer_content_height;
  if (g_doc_len <= 0) { est_h = 0; }
  var max_scroll: int32 = est_h - view_h;
  if (max_scroll < 0) { return 0; }
  return max_scroll;
}

function viewer_recompute_content_height() {
  g_viewer_content_height = viewer_total_content_height();
}

function invalidate_area(hwnd: int64, rect: UiRect) {
  Win_InvalidateRect(hwnd, &rect, 0);
}

function invalidate_sidebar_list(hwnd: int64) {
  var rect: UiRect = ui_make_rect(g_content_left, sidebar_list_top(), g_sidebar_right, sidebar_list_bottom());
  invalidate_area(hwnd, rect);
}

function invalidate_viewer_panel(hwnd: int64) {
  var rect: UiRect = ui_make_rect(g_viewer_left, g_viewer_top, g_viewer_right, g_viewer_bottom);
  invalidate_area(hwnd, rect);
}

function invalidate_hero(hwnd: int64) {
  var rect: UiRect = ui_make_rect(g_content_left, g_content_top, g_content_right, g_content_top + 96);
  invalidate_area(hwnd, rect);
}

function invalidate_client(hwnd: int64) {
  var rect: UiRect = ui_window_client_rect(hwnd);
  invalidate_area(hwnd, rect);
}

function invalidate_after_doc_load() {
  invalidate_hero(g_main_window);
  invalidate_sidebar_list(g_main_window);
  invalidate_viewer_panel(g_main_window);
}

function viewer_draw_table_row(
  hdc: int64,
  y: int32,
  raw: cstring,
  kind: int32,
  height: int32,
  fg: uint32,
  bg: uint32,
  font: int64,
  top_pad: int32) -> int32 {
  var left: int32 = viewer_text_left();
  var right: int32 = viewer_text_right();
  var block_top: int32 = y + top_pad;
  var block_bottom: int32 = block_top + height;
  var row: UiRect = ui_make_rect(left, block_top, right, block_bottom);
  var block_h: int32 = top_pad + height;

  table_compute_column_layout();

  ui_fill_rect_color_rect(hdc, &row, bg);

  if (kind == VIEWER_KIND_TABLE_HEADER()) {
    var top_border: UiRect = ui_make_rect(left, block_top, right - 8, block_top + 1);
    ui_fill_rect_color_rect(hdc, &top_border, accent_dark());
  }
  var row_border: UiRect = ui_make_rect(left, block_bottom - 1, right - 8, block_bottom);
  ui_fill_rect_color_rect(hdc, &row_border, ui_rgb(226, 232, 240));

  if (font == 0) { font = g_body_font; }
  var old_font: int64 = ui_select_object(hdc, font);

  var col: int32 = 0;
  var cell: uint8[160];
  var cell_rect: UiRect;
  var divider: UiRect;
  while (col < g_table_num_cols && col < TABLE_MAX_COLS()) {
    var cell_len: int32 = table_copy_cell(raw, col, &cell[0], 160);

    var cell_left: int32 = table_col_px_get(col) + 4;
    var cell_right: int32 = right - 8;
    if (col + 1 < g_table_num_cols) {
      cell_right = table_col_px_get(col + 1) - 5;
    }
    if (cell_right <= cell_left + 40) {
      cell_right = cell_left + 40;
    }

    cell_rect = ui_make_rect(cell_left, block_top + 2, cell_right, block_bottom - 2);
    if (cell_len > 0) {
      ui_draw_text_rect_color(
        hdc, &cell_rect, &cell[0], fg,
        UI_DT_LEFT() | UI_DT_SINGLELINE() | UI_DT_END_ELLIPSIS());
    }

    if (col + 1 < g_table_num_cols) {
      divider = ui_make_rect(cell_right + 1, block_top + 2, cell_right + 2, block_bottom - 2);
      ui_fill_rect_color_rect(hdc, &divider, ui_rgb(203, 213, 225));
    }
    col = col + 1;
  }

  ui_select_object(hdc, old_font);
  return block_h;
}

function viewer_draw_line(
  hdc: int64,
  y: int32,
  kind: int32,
  text: cstring,
  height: int32,
  indent: int32,
  fg: uint32,
  bg: uint32,
  use_bg: int32,
  font: int64,
  wrap: int32,
  rule: int32,
  quote_bar: int32,
  underline: int32,
  top_pad: int32) -> int32 {
  var left: int32 = viewer_text_left() + indent;
  var right: int32 = viewer_text_right();
  var block_top: int32 = y + top_pad;
  var block_bottom: int32 = block_top + height;
  var row: UiRect = ui_make_rect(viewer_text_left(), block_top, right, block_bottom);
  var text_rect: UiRect = ui_make_rect(left, block_top + 2, right - 4, block_bottom - 2);
  if (font == 0) { font = g_body_font; }
  var old_font: int64 = ui_select_object(hdc, font);
  var block_h: int32 = top_pad + height;

  if (use_bg != 0) {
    ui_fill_rect_color_rect(hdc, &row, bg);
  }
  if (kind == VIEWER_KIND_TABLE_SEP()) {
    var sep_rect: UiRect = ui_make_rect(viewer_text_left(), block_top + 2, right - 8, block_top + 3);
    ui_fill_rect_color_rect(hdc, &sep_rect, ui_rgb(203, 213, 225));
    ui_select_object(hdc, old_font);
    return block_h;
  }
  if (rule != 0) {
    var rule_rect: UiRect = ui_make_rect(left, block_top + 8, right - 8, block_top + 10);
    ui_fill_rect_color_rect(hdc, &rule_rect, accent_color());
    ui_select_object(hdc, old_font);
    return block_h;
  }
  if (quote_bar != 0) {
    var bar: UiRect = ui_make_rect(viewer_text_left() + 6, block_top + 2, viewer_text_left() + 10, block_bottom - 2);
    ui_fill_rect_color_rect(hdc, &bar, accent_color());
  }
  if (kind == VIEWER_KIND_BULLET()) {
    var dot: UiRect = ui_make_rect(viewer_text_left() + 8, block_top + 8, viewer_text_left() + 14, block_top + 14);
    ui_fill_rect_color_rect(hdc, &dot, accent_color());
  }
  if (text[0] != 0) {
    if (wrap != 0) {
      ui_draw_text_rect_color(
        hdc, &text_rect, text, fg,
        UI_DT_LEFT() | UI_DT_WORDBREAK());
      var drawn_h: int32 = text_rect.bottom - block_top;
      if (drawn_h + 6 > height) {
        block_h = top_pad + drawn_h + 6;
      }
    } else {
      ui_draw_text_rect_color(
        hdc, &text_rect, text, fg,
        UI_DT_LEFT() | UI_DT_SINGLELINE() | UI_DT_END_ELLIPSIS());
    }
  }
  if (underline != 0) {
    var line_rect: UiRect = ui_make_rect(left, block_top + height - 4, right - 8, block_top + height - 2);
    ui_fill_rect_color_rect(hdc, &line_rect, accent_color());
  }
  ui_select_object(hdc, old_font);
  return block_h;
}

function draw_viewer_content(hdc: int64, theme: UiTheme) {
  var top: int32 = viewer_content_top();
  var bottom: int32 = viewer_content_bottom();
  var y: int32 = top - g_viewer_scroll;
  var line: int32 = 0;
  var in_code: int32 = 0;
  var in_table: int32 = 0;
  var raw: uint8[512];
  var draw: uint8[512];
  var text_rect: UiRect;

  if (g_doc_len <= 0) {
    text_rect = ui_make_rect(viewer_text_left(), top, viewer_text_right(), top + 24);
    ui_draw_text_rect_color(
      hdc, &text_rect,
      cstr("Select a document from the sidebar."),
      theme.muted_text,
      UI_DT_LEFT() | UI_DT_SINGLELINE());
    return;
  }

  while (line < g_doc_lines) {
    doc_line_at(line, &raw[0], 512);
    var kind: int32 = viewer_classify_line_at(line, &raw[0], in_code);
    if (kind == VIEWER_KIND_FENCE()) {
      in_code = 1 - in_code;
    }
    if (kind == VIEWER_KIND_TABLE() || kind == VIEWER_KIND_TABLE_HEADER()) {
      if (in_table == 0) {
        table_measure_block(line);
        g_table_body_row = 0;
        in_table = 1;
      }
    } else if (kind != VIEWER_KIND_TABLE_SEP()) {
      in_table = 0;
    }
    if (kind == VIEWER_KIND_TABLE()) {
      g_table_stripe = g_table_body_row % 2;
      g_table_body_row = g_table_body_row + 1;
    }
    viewer_format_line(&raw[0], kind, &draw[0], 512);
    var metrics: ViewerLineMetrics = viewer_line_metrics(kind, &draw[0], theme);
    var block_h: int32 = metrics.top_pad + metrics.height;

    if (y + block_h <= top) {
      y = y + block_h;
      line = line + 1;
      continue;
    }
    if (y >= bottom) { break; }

    if (kind != VIEWER_KIND_BLANK() && kind != VIEWER_KIND_FENCE()) {
      if (kind == VIEWER_KIND_TABLE() || kind == VIEWER_KIND_TABLE_HEADER()) {
        block_h = viewer_draw_table_row(
          hdc, y, &raw[0], kind,
          metrics.height, metrics.fg, metrics.bg, metrics.font, metrics.top_pad);
      } else {
        block_h = viewer_draw_line(
          hdc, y, kind, &draw[0],
          metrics.height, metrics.indent, metrics.fg, metrics.bg, metrics.use_bg,
          metrics.font, metrics.wrap, metrics.rule, metrics.quote_bar, metrics.underline,
          metrics.top_pad);
      }
    }
    y = y + block_h;
    line = line + 1;
  }
}

function viewer_clamp_scroll() {
  g_viewer_scroll = ui_clamp_i32(g_viewer_scroll, 0, viewer_max_scroll());
}

function utf8_copy_chunk(out: cstring, out_len: int32, write: int32, chunk: cstring) -> int32 {
  var i: int32 = 0;
  while (chunk[i] != 0 && write + 1 < out_len) {
    out[write] = chunk[i];
    write = write + 1;
    i = i + 1;
  }
  return write;
}

function utf8_skip_multibyte(src: cstring, read: int32) -> int32 {
  var b0: uint8 = src[read];
  if (b0 < 128) { return read + 1; }
  if (b0 >= 192 && b0 < 224) { return read + 2; }
  if (b0 >= 224 && b0 < 240) { return read + 3; }
  if (b0 >= 240 && b0 < 248) { return read + 4; }
  return read + 1;
}

// DrawTextA expects ANSI; docs are UTF-8. Map common punctuation to ASCII.
function utf8_normalize_ascii(src: cstring, out: cstring, out_len: int32) {
  var read: int32 = 0;
  var write: int32 = 0;
  while (src[read] != 0 && write + 1 < out_len) {
    var b0: uint8 = src[read];
    var b1: uint8 = src[read + 1];
    var b2: uint8 = src[read + 2];

    if (b0 == 226 && b1 == 128) {
      if (b2 == 148) {
        write = utf8_copy_chunk(out, out_len, write, cstr(" - "));
        read = read + 3;
        continue;
      }
      if (b2 == 147) {
        write = utf8_copy_chunk(out, out_len, write, cstr("-"));
        read = read + 3;
        continue;
      }
      if (b2 == 153 || b2 == 152) {
        write = utf8_copy_chunk(out, out_len, write, cstr("'"));
        read = read + 3;
        continue;
      }
      if (b2 == 156 || b2 == 157) {
        write = utf8_copy_chunk(out, out_len, write, cstr("\""));
        read = read + 3;
        continue;
      }
      if (b2 == 166) {
        write = utf8_copy_chunk(out, out_len, write, cstr("..."));
        read = read + 3;
        continue;
      }
      if (b2 == 162) {
        write = utf8_copy_chunk(out, out_len, write, cstr("-"));
        read = read + 3;
        continue;
      }
    }

    if (b0 == 226 && b1 == 134 && b2 == 146) {
      write = utf8_copy_chunk(out, out_len, write, cstr("->"));
      read = read + 3;
      continue;
    }

    if (b0 == 194 && b1 == 160) {
      out[write] = 32;
      write = write + 1;
      read = read + 2;
      continue;
    }

    if (b0 < 128) {
      out[write] = b0;
      write = write + 1;
      read = read + 1;
      continue;
    }

    read = utf8_skip_multibyte(src, read);
  }
  out[write] = 0;
}

function draw_viewer_scrollbar(hdc: int64, theme: UiTheme) {
  var max_scroll: int32 = viewer_max_scroll();
  if (max_scroll <= 0) { return; }

  var track: UiRect = ui_make_rect(
    g_viewer_right - 10, viewer_content_top(),
    g_viewer_right - 4, viewer_content_bottom());
  ui_fill_rect_color_rect(hdc, &track, ui_rgb(241, 245, 249));
  ui_frame_rect_color(hdc, &track, theme.border);

  var track_h: int32 = ui_rect_height(track);
  var thumb_h: int32 = track_h / 5;
  if (thumb_h < 20) { thumb_h = 20; }
  var travel: int32 = track_h - thumb_h;
  var thumb_y: int32 = track.top + (travel * g_viewer_scroll) / max_scroll;
  var thumb: UiRect = ui_make_rect(track.left, thumb_y, track.right, thumb_y + thumb_h);
  ui_fill_rect_color_rect(hdc, &thumb, accent_color());
}

function sidebar_list_top() -> int32 {
  return g_viewer_top + 36;
}

function sidebar_list_bottom() -> int32 {
  return g_viewer_bottom - 10;
}

function sidebar_visible_rows() -> int32 {
  var height: int32 = sidebar_list_bottom() - sidebar_list_top();
  if (height <= 0) { return 0; }
  return height / SIDEBAR_ROW_HEIGHT();
}

function sidebar_max_scroll() -> int32 {
  var max_scroll: int32 = g_doc_count - sidebar_visible_rows();
  if (max_scroll < 0) { return 0; }
  return max_scroll;
}

function sidebar_clamp_scroll() {
  g_sidebar_scroll = ui_clamp_i32(g_sidebar_scroll, 0, sidebar_max_scroll());
}

function sidebar_contains(x: int32, y: int32) -> int32 {
  if (x < g_content_left) { return 0; }
  if (x >= g_sidebar_right) { return 0; }
  if (y < sidebar_list_top()) { return 0; }
  if (y >= sidebar_list_bottom()) { return 0; }
  return 1;
}

function sidebar_doc_at(x: int32, y: int32) -> int32 {
  if (sidebar_contains(x, y) == 0) { return -1; }
  var row: int32 = (y - sidebar_list_top()) / SIDEBAR_ROW_HEIGHT() + g_sidebar_scroll;
  if (row < 0) { return -1; }
  if (row >= g_doc_count) { return -1; }
  return row;
}

function draw_sidebar_docs(hdc: int64, theme: UiTheme) {
  var y: int32 = sidebar_list_top();
  var bottom: int32 = sidebar_list_bottom();
  var index: int32 = g_sidebar_scroll;
  var label: uint8[128];
  var text_rect: UiRect;

  while (index < g_doc_count && y + SIDEBAR_ROW_HEIGHT() <= bottom) {
    doc_label_from_path(path_slot(index), &label[0], 128);
    var row: UiRect = ui_make_rect(g_content_left + 10, y, g_sidebar_right - 24, y + SIDEBAR_ROW_HEIGHT());
    var bg: uint32 = ui_rgb(255, 255, 255);
    var fg: uint32 = theme.text;

    if (index == g_selected_doc) {
      bg = accent_color();
      fg = ui_rgb(255, 255, 255);
    } else if (index == g_sidebar_hover) {
      bg = ui_rgb(241, 245, 249);
    }

    ui_fill_rect_color_rect(hdc, &row, bg);
    text_rect = ui_make_rect(row.left + 10, row.top + 6, row.right - 10, row.bottom - 4);
    ui_draw_text_rect_color(hdc, &text_rect, &label[0], fg, UI_DT_LEFT() | UI_DT_SINGLELINE() | UI_DT_END_ELLIPSIS());
    y = y + SIDEBAR_ROW_HEIGHT();
    index = index + 1;
  }

  var max_scroll: int32 = sidebar_max_scroll();
  if (max_scroll > 0) {
    var track: UiRect = ui_make_rect(g_sidebar_right - 22, sidebar_list_top(), g_sidebar_right - 12, sidebar_list_bottom());
    ui_fill_rect_color_rect(hdc, &track, ui_rgb(241, 245, 249));
    var track_h: int32 = ui_rect_height(track);
    var thumb_h: int32 = track_h / 5;
    if (thumb_h < 20) { thumb_h = 20; }
    var travel: int32 = track_h - thumb_h;
    var thumb_y: int32 = track.top + (travel * g_sidebar_scroll) / max_scroll;
    var thumb: UiRect = ui_make_rect(track.left, thumb_y, track.right, thumb_y + thumb_h);
    ui_fill_rect_color_rect(hdc, &thumb, accent_color());
  }
}

function build_menu(hwnd: int64) {
  var menu: int64 = ui_menu_create();
  var file_menu: int64 = ui_menu_popup_create();
  ui_menu_append_item(file_menu, ID_RELOAD(), cstr("Reload docs\tF5"));
  ui_menu_append_separator(file_menu);
  ui_menu_append_item(file_menu, ID_ABOUT(), cstr("About"));
  ui_menu_append_separator(file_menu);
  ui_menu_append_item(file_menu, ID_EXIT(), cstr("Exit\tEsc"));
  ui_menu_append_popup(menu, file_menu, cstr("File"));
  ui_window_set_menu(hwnd, menu);
}

function compute_layout(hwnd: int64) {
  var client: UiRect = ui_window_client_rect(hwnd);
  var content: UiRect = ui_rect_inset(client, ui_make_insets(24));
  g_content_left = content.left;
  g_content_top = content.top;
  g_content_right = content.right;
  g_content_bottom = content.bottom;

  var sidebar_w: int32 = 300;
  if (sidebar_w > ui_rect_width(content) / 2) {
    sidebar_w = ui_rect_width(content) / 2;
  }
  if (sidebar_w < 240) { sidebar_w = 240; }

  g_sidebar_right = g_content_left + sidebar_w;
  g_viewer_left = g_sidebar_right + 20;
  g_viewer_top = g_content_top + 118;
  g_viewer_right = g_content_right;
  g_viewer_bottom = g_content_bottom - 36;

  ui_control_move(g_status_label, g_content_left, g_content_bottom - 28, ui_rect_width(content), 22);
  ui_control_move(g_theme_combo, g_content_right - 190, g_content_top + 72, 180, 160);
  sidebar_clamp_scroll();
  viewer_clamp_scroll();
  viewer_recompute_content_height();
}

function build_controls(hwnd: int64) {
  g_status_label = ui_label_create(hwnd, 0, 0, 400, 22, cstr("Loading docs..."), ID_STATUS());
  g_theme_combo = ui_combobox_create(hwnd, 0, 0, 180, 160, ID_THEME());

  ui_control_set_font(g_status_label, g_small_font);
  ui_control_set_font(g_theme_combo, g_body_font);

  ui_combobox_add(g_theme_combo, cstr("Blue"));
  ui_combobox_add(g_theme_combo, cstr("Cyan"));
  ui_combobox_add(g_theme_combo, cstr("Violet"));
  ui_combobox_select(g_theme_combo, 0);

  compute_layout(hwnd);
}

function paint_client(hdc: int64) {
  var theme: UiTheme = ui_default_theme();
  var client: UiRect = ui_window_client_rect(g_main_window);
  var content: UiRect = ui_make_rect(g_content_left, g_content_top, g_content_right, g_content_bottom);
  var hero: UiRect = ui_make_rect(content.left, content.top, content.right, content.top + 96);
  var sidebar_panel: UiRect = ui_make_rect(g_content_left, g_viewer_top, g_sidebar_right, g_viewer_bottom);
  var viewer_panel: UiRect = ui_make_rect(g_viewer_left, g_viewer_top, g_viewer_right, g_viewer_bottom);

  ui_fill_rect_color_rect(hdc, &client, theme.background);
  ui_fill_rect_color_rect(hdc, &hero, accent_color());
  ui_frame_rect_color(hdc, &hero, accent_dark());

  var old_font: int64 = ui_select_object(hdc, g_title_font);
  var title_rect: UiRect = ui_make_rect(hero.left + 22, hero.top + 16, hero.right - 220, hero.top + 52);
  ui_draw_text_rect_color(hdc, &title_rect, cstr("Mettle Documentation"), theme.accent_text, UI_DT_LEFT() | UI_DT_SINGLELINE());
  ui_select_object(hdc, old_font);

  var subtitle: UiRect = ui_make_rect(hero.left + 24, hero.top + 56, hero.right - 220, hero.bottom - 14);
  ui_draw_text_rect_color(
    hdc, &subtitle,
    cstr("Browse docs/ from disk with native scrolling, wrapped prose, and readable headings."),
    ui_rgb(229, 241, 255),
    UI_DT_LEFT() | UI_DT_WORDBREAK());

  var doc_title_rect: UiRect = ui_make_rect(hero.right - 380, hero.top + 20, hero.right - 24, hero.top + 52);
  ui_draw_text_rect_color(hdc, &doc_title_rect, g_current_title, theme.accent_text, UI_DT_RIGHT() | UI_DT_SINGLELINE() | UI_DT_END_ELLIPSIS());

  var count_buf: uint8[48];
  format_i64(&count_buf[0], 48, "%d documents", g_doc_count);
  var count_rect: UiRect = ui_make_rect(hero.right - 380, hero.top + 56, hero.right - 24, hero.bottom - 14);
  ui_draw_text_rect_color(hdc, &count_rect, &count_buf[0], ui_rgb(219, 234, 254), UI_DT_RIGHT() | UI_DT_SINGLELINE());

  ui_fill_rect_color_rect(hdc, &sidebar_panel, ui_rgb(255, 255, 255));
  ui_frame_rect_color(hdc, &sidebar_panel, theme.border);
  ui_fill_rect_color_rect(hdc, &viewer_panel, ui_rgb(255, 255, 255));
  ui_frame_rect_color(hdc, &viewer_panel, theme.border);

  old_font = ui_select_object(hdc, g_small_font);
  var sidebar_title: UiRect = ui_make_rect(g_content_left + 16, g_viewer_top + 12, g_sidebar_right - 12, g_viewer_top + 28);
  ui_draw_text_rect_color(hdc, &sidebar_title, cstr("Documents"), theme.muted_text, UI_DT_SINGLELINE());
  ui_select_object(hdc, old_font);

  draw_sidebar_docs(hdc, theme);
  draw_viewer_content(hdc, theme);
  draw_viewer_scrollbar(hdc, theme);
}

function on_paint(hwnd: int64) {
  var ps: UiPaintStruct;
  var hdc: int64 = ui_begin_paint(hwnd, &ps);
  var client: UiRect = ui_window_client_rect(hwnd);
  var width: int32 = ui_rect_width(client);
  var height: int32 = ui_rect_height(client);

  if (width > 0 && height > 0) {
    var mem_dc: int64 = Win_CreateCompatibleDC(hdc);
    if (mem_dc != 0) {
      var bmp: int64 = Win_CreateCompatibleBitmap(hdc, width, height);
      if (bmp != 0) {
        var old_bmp: int64 = ui_select_object(mem_dc, bmp);
        paint_client(mem_dc);
        Win_BitBlt(hdc, 0, 0, width, height, mem_dc, 0, 0, UI_SRCCOPY());
        ui_select_object(mem_dc, old_bmp);
        ui_delete_object(bmp);
      }
      Win_DeleteDC(mem_dc);
    } else {
      paint_client(hdc);
    }
  }

  ui_end_paint(hwnd, &ps);
}

function reload_docs() -> int32 {
  var keep_index: int32 = g_selected_doc;
  if (resolve_docs_root() == 0) {
    set_status(cstr("Could not locate docs/ (expected LANGUAGE.md)."));
    return 0;
  }
  if (scan_docs() <= 0) {
    set_status(cstr("No Markdown files found under docs/."));
    return 0;
  }
  if (keep_index < 0) { keep_index = 0; }
  if (keep_index >= g_doc_count) { keep_index = 0; }
  load_doc(keep_index);
  return 1;
}

function window_proc(hwnd: int64, msg: uint32, wparam: int64, lparam: int64) -> int64 {
  if (msg == UI_WM_ERASEBKGND()) { return 1; }

  if (msg == UI_WM_PAINT()) {
    on_paint(hwnd);
    return 0;
  }

  if (msg == UI_WM_SIZE()) {
    compute_layout(hwnd);
    invalidate_client(hwnd);
    return 0;
  }

  if (msg == UI_WM_MOUSEMOVE()) {
    g_mouse_x = ui_mouse_x(lparam);
    g_mouse_y = ui_mouse_y(lparam);
    var hover: int32 = sidebar_doc_at(g_mouse_x, g_mouse_y);
    if (hover != g_sidebar_hover) {
      g_sidebar_hover = hover;
      invalidate_sidebar_list(hwnd);
    }
    return 0;
  }

  if (msg == UI_WM_LBUTTONDOWN()) {
    var x: int32 = ui_mouse_x(lparam);
    var y: int32 = ui_mouse_y(lparam);
    var index: int32 = sidebar_doc_at(x, y);
    if (index >= 0) {
      select_doc_index(index);
      return 0;
    }
  }

  if (msg == UI_WM_MOUSEWHEEL()) {
    var delta: int32 = (int32)((wparam >> 16) & 0xFFFF);
    if (delta >= 32768) { delta = delta - 65536; }
    if (delta != 0 && sidebar_contains(g_mouse_x, g_mouse_y) != 0) {
      g_sidebar_scroll = g_sidebar_scroll - delta / 120;
      sidebar_clamp_scroll();
      invalidate_sidebar_list(hwnd);
      return 0;
    }
    if (delta != 0 && viewer_contains(g_mouse_x, g_mouse_y) != 0) {
      g_viewer_scroll = g_viewer_scroll - (delta / 120) * 22;
      viewer_clamp_scroll();
      invalidate_viewer_panel(hwnd);
      return 0;
    }
  }

  if (msg == UI_WM_KEYDOWN()) {
    if (wparam == VK_ESCAPE()) { ui_window_close(hwnd); return 0; }
    if (wparam == VK_F5()) { reload_docs(); return 0; }
  }

  if (msg == UI_WM_COMMAND()) {
    var id: uint32 = ui_command_id(wparam);
    var notify: uint32 = ui_command_notify(wparam);

    if (id == (uint32)ID_EXIT()) { ui_window_close(hwnd); return 0; }
    if (id == (uint32)ID_RELOAD()) { reload_docs(); return 0; }
    if (id == (uint32)ID_ABOUT()) {
      ui_alert(
        hwnd, cstr("Mettle Documentation Browser"),
        cstr("Click a document in the sidebar to open it.\nThe viewer converts Markdown to readable text.\nF5 reloads the catalog."));
      return 0;
    }

    if (id == (uint32)ID_THEME()) {
      if (notify == UI_CBN_SELCHANGE()) {
        g_theme_index = ui_combobox_selected(g_theme_combo);
        invalidate_client(hwnd);
        return 0;
      }
    }
  }

  if (msg == UI_WM_DESTROY()) {
    if (g_title_font != 0) { ui_delete_object(g_title_font); }
    if (g_h1_font != 0) { ui_delete_object(g_h1_font); }
    if (g_h2_font != 0) { ui_delete_object(g_h2_font); }
    if (g_h3_font != 0) { ui_delete_object(g_h3_font); }
    if (g_body_font != 0) { ui_delete_object(g_body_font); }
    if (g_code_font != 0) { ui_delete_object(g_code_font); }
    if (g_small_font != 0) { ui_delete_object(g_small_font); }
    free_buffers();
    ui_quit(0);
    return 0;
  }

  return ui_def_window_proc(hwnd, msg, wparam, lparam);
}

function alloc_buffers() -> int32 {
  g_paths_blob = malloc(PATHS_BUF_SIZE());
  g_path_slots = malloc(PATH_SLOT_SIZE() * MAX_DOCS());
  g_doc_buf = malloc(DOC_BUF_SIZE());
  g_display_buf = malloc(DISPLAY_BUF_SIZE());
  g_doc_root = malloc(512);
  g_current_rel = malloc(512);
  g_current_title = malloc(128);
  if (g_paths_blob == 0) { return 0; }
  if (g_path_slots == 0) { return 0; }
  if (g_doc_buf == 0) { return 0; }
  if (g_display_buf == 0) { return 0; }
  if (g_doc_root == 0) { return 0; }
  if (g_current_rel == 0) { return 0; }
  if (g_current_title == 0) { return 0; }
  g_doc_root[0] = 0;
  g_current_rel[0] = 0;
  g_current_title[0] = 0;
  return 1;
}

function free_buffers() {
  if (g_paths_blob != 0) { free(g_paths_blob); g_paths_blob = 0; }
  if (g_path_slots != 0) { free(g_path_slots); g_path_slots = 0; }
  if (g_doc_buf != 0) { free(g_doc_buf); g_doc_buf = 0; }
  if (g_display_buf != 0) { free(g_display_buf); g_display_buf = 0; }
  if (g_doc_root != 0) { free(g_doc_root); g_doc_root = 0; }
  if (g_current_rel != 0) { free(g_current_rel); g_current_rel = 0; }
  if (g_current_title != 0) { free(g_current_title); g_current_title = 0; }
}

function main() -> int32 {
  if (ui_init() == 0) { return 1; }
  if (alloc_buffers() == 0) { return 1; }

  g_title_font = ui_create_font(28, cstr("Segoe UI"), UI_FW_BOLD());
  g_h1_font = ui_create_font(24, cstr("Segoe UI"), UI_FW_BOLD());
  g_h2_font = ui_create_font(20, cstr("Segoe UI"), UI_FW_BOLD());
  g_h3_font = ui_create_font(17, cstr("Segoe UI"), UI_FW_BOLD());
  g_body_font = ui_create_font(16, cstr("Segoe UI"), UI_FW_NORMAL());
  g_code_font = ui_create_font(14, cstr("Consolas"), UI_FW_NORMAL());
  g_small_font = ui_create_font(13, cstr("Segoe UI"), UI_FW_NORMAL());

  g_main_window = ui_window_create_centered(cstr("Mettle Documentation"), 1080, 760, &window_proc);
  if (g_main_window == 0) { return 2; }

  build_menu(g_main_window);
  build_controls(g_main_window);
  ui_window_show(g_main_window);

  if (reload_docs() == 0) {
    set_status(cstr("Run from the repository root so docs/ can be found."));
  }

  return ui_run_message_loop();
}
