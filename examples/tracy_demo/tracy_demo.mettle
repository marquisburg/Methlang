// Mettle Tracy Demo
//
// Simulates a frame-based app with nested zones, plots, memory tracking,
// background loading on a worker thread, and intentional frame hitches.
//
// Build: examples\tracy_demo\build.bat
// Run Tracy Profiler, connect to tracy_demo.exe, then explore the timeline.

import "std/io";
import "std/mem";
import "std/bench";
import "std/conv";
import "std/tracy";
import "std/thread";

var DEMO_FILE: cstring = 0;
var g_shutdown: int32 = 0;
var g_load_progress: int32 = 0;
var g_load_target: int32 = 100;
var g_entity_count: int32 = 64;
var g_heap_bytes: int64 = 0;
var g_loader_thread: int64 = 0;
var g_scratch: cstring = 0;
var g_render_buf: cstring = 0;

var MAT_N: int32 = 16;
var SORT_LEN: int32 = 128;

function demo_file() -> cstring {
  if (DEMO_FILE == 0) {
    DEMO_FILE = cstr("examples/tracy_demo/tracy_demo.mettle");
  }
  return DEMO_FILE;
}

function fill_matrix(m: int32*, n: int32, seed: int32) {
  var row: int32 = 0;
  while (row < n) {
    var col: int32 = 0;
    while (col < n) {
      var idx: int64 = (int64)row * (int64)n + (int64)col;
      m[idx] = (row * 131 + col * 17 + seed) % 251;
      col = col + 1;
    }
    row = row + 1;
  }
}

function matmul_small(a: int32*, b: int32*, c: int32*, n: int32) {
  var row: int32 = 0;
  while (row < n) {
    var col: int32 = 0;
    while (col < n) {
      var sum: int32 = 0;
      var k: int32 = 0;
      while (k < n) {
        var a_idx: int64 = (int64)row * (int64)n + (int64)k;
        var b_idx: int64 = (int64)k * (int64)n + (int64)col;
        sum = sum + a[a_idx] * b[b_idx];
        k = k + 1;
      }
      var c_idx: int64 = (int64)row * (int64)n + (int64)col;
      c[c_idx] = sum;
      col = col + 1;
    }
    row = row + 1;
  }
}

function fill_sort_data(data: int32*, len: int32, seed: int32) {
  var i: int32 = 0;
  while (i < len) {
    data[i] = (i * 1103515245 + seed + 12345) % 1024;
    i = i + 1;
  }
}

function insertion_sort_small(data: int32*, len: int32) {
  var i: int32 = 1;
  while (i < len) {
    var key: int32 = data[i];
    var j: int32 = i - 1;
    while (j >= 0) {
      if (data[j] <= key) {
        break;
      }
      data[j + 1] = data[j];
      j = j - 1;
    }
    data[j + 1] = key;
    i = i + 1;
  }
}

function simulate_input(frame_no: int32) {
  var z: TracyZone = tracy_zone_colored(
    cstr("Input"),
    demo_file(),
    97,
    cstr("simulate_input"),
    tracy_color_input()
  );
  defer tracy_scope_end(z);
  var _unused: int32 = frame_no + g_entity_count;
}

function simulate_physics(frame_no: int32) -> int32 {
  var z: TracyZone = tracy_zone_colored(
    cstr("Physics"),
    demo_file(),
    110,
    cstr("simulate_physics"),
    tracy_color_update()
  );
  defer tracy_scope_end(z);
  var acc: int32 = 0;
  var i: int32 = 0;
  while (i < 800) {
    acc = acc + (i * 3) - (frame_no % 7);
    i = i + 1;
  }
  return acc;
}

function simulate_gameplay(frame_no: int32) -> int32 {
  var z: TracyZone = tracy_zone_colored(
    cstr("Gameplay"),
    demo_file(),
    127,
    cstr("simulate_gameplay"),
    tracy_color_update()
  );
  defer tracy_scope_end(z);
  tracy_zone_value(z, (uint64)g_entity_count);
  var data: int32[128];
  fill_sort_data(&data[0], SORT_LEN, frame_no + 17);
  insertion_sort_small(&data[0], SORT_LEN);
  return data[0] + data[SORT_LEN - 1];
}

function simulate_simulation(frame_no: int32) -> int32 {
  var z: TracyZone = tracy_zone_colored(
    cstr("Simulation"),
    demo_file(),
    143,
    cstr("simulate_simulation"),
    tracy_color_update()
  );
  defer tracy_scope_end(z);
  var p: int32 = simulate_physics(frame_no);
  var g: int32 = simulate_gameplay(frame_no);
  return p + g;
}

function simulate_render_prep(frame_no: int32) -> int32 {
  var z: TracyZone = tracy_zone_colored(
    cstr("RenderPrep"),
    demo_file(),
    155,
    cstr("simulate_render_prep"),
    tracy_color_render()
  );
  defer tracy_scope_end(z);
  var a: int32[256];
  var b: int32[256];
  var c: int32[256];
  fill_matrix(&a[0], MAT_N, frame_no);
  fill_matrix(&b[0], MAT_N, frame_no + 3);
  matmul_small(&a[0], &b[0], &c[0], MAT_N);
  return c[0] + c[255];
}

function run_frame(frame_no: int32, hitch: int32) -> int32 {
  var z: TracyZone = tracy_zone(
    cstr("Frame"),
    demo_file(),
    171,
    cstr("run_frame")
  );
  defer tracy_scope_end(z);

  if (hitch != 0) {
    tracy_zone_text(z, cstr("shader recompile hitch"));
    tracy_message_colored(cstr("Frame hitch: simulated shader recompile"), tracy_color_warn());
    thread_sleep_ms(45);
  }

  simulate_input(frame_no);
  var sim: int32 = simulate_simulation(frame_no);
  var render: int32 = simulate_render_prep(frame_no);
  return sim + render;
}

function asset_loader_thread(_param: cstring) -> uint32 {
  tracy_set_thread_name(cstr("AssetLoader"));
  var progress_buf: uint8[32];

  while (g_load_progress < g_load_target && g_shutdown == 0) {
    var z: TracyZone = tracy_zone_colored(
      cstr("BackgroundLoad"),
      demo_file(),
      199,
      cstr("asset_loader_thread"),
      tracy_color_load()
    );
    defer tracy_scope_end(z);

    format_i64(&progress_buf[0], 32, "load %d/100", (int64)g_load_progress);
    tracy_zone_text(z, &progress_buf[0]);

    var i: int32 = 0;
    while (i < 50000) {
      var _acc: int32 = i * i;
      i = i + 1;
    }
    thread_sleep_ms(20);
    g_load_progress = g_load_progress + 1;
  }

  tracy_message_literal(cstr("Asset loader finished"));
  return 0;
}

function setup_plots() {
  tracy_plot_setup_number(cstr("frame_ms"), 1, 1, tracy_color_render());
  tracy_plot_setup_number(cstr("entity_count"), 1, 0, tracy_color_update());
  tracy_plot_setup_memory(cstr("heap_bytes"), 1024, 1, tracy_color_load());
}

function setup_memory() {
  var scratch_size: int64 = 65536;
  var render_size: int64 = 4096;
  g_scratch = tracy_malloc(scratch_size);
  g_render_buf = tracy_malloc(render_size);
  if (g_scratch != 0) {
    memset(g_scratch, 0, scratch_size);
  }
  if (g_render_buf != 0) {
    memset(g_render_buf, 0, render_size);
  }
  g_heap_bytes = scratch_size + render_size;
}

function teardown_memory() {
  tracy_heap_free(g_scratch);
  tracy_heap_free(g_render_buf);
  g_scratch = 0;
  g_render_buf = 0;
  g_heap_bytes = 0;
}

function start_loader_thread() {
  g_load_progress = 0;
  g_loader_thread = CreateThread(0, 0, &asset_loader_thread, 0, 0, 0);
}

function stop_loader_thread() {
  if (g_loader_thread == 0) {
    return;
  }
  thread_join_infinite(g_loader_thread);
  thread_close(g_loader_thread);
  g_loader_thread = 0;
}

function main() -> int32 {
  tracy_app_info(cstr("Mettle Tracy Demo — frame pipeline + loader thread"));
  tracy_set_thread_name(cstr("Main"));
  setup_plots();

  if (tracy_connected() != 0) {
    tracy_message_literal(cstr("Tracy connected — profiling active"));
  } else {
    tracy_message_literal(cstr("Tracy not connected — zones are no-ops until profiler attaches"));
  }

  println(cstr("Mettle Tracy Demo"));
  println(cstr("  Connect Tracy Profiler, then watch zones/plots/memory/threads."));
  println(cstr("  Intentional hitches every 90 frames."));

  setup_memory();
  start_loader_thread();

  var max_frames: int32 = 600;
  var frame: int32 = 0;
  while (frame < max_frames) {
    var t0: uint64 = bench_time_us();
    var hitch: int32 = 0;
    if (frame > 0) {
      if (frame - (frame / 90) * 90 == 0) {
        hitch = 1;
      }
    }
    var _result: int32 = run_frame(frame, hitch);
    var frame_us: uint64 = bench_time_us() - t0;
    var frame_ms: int64 = (int64)(frame_us / 1000);
    tracy_plot_int(cstr("frame_ms"), frame_ms);
    tracy_plot_int(cstr("entity_count"), (int64)g_entity_count);
    tracy_plot_int(cstr("heap_bytes"), g_heap_bytes);
    tracy_frame_mark();
    thread_sleep_ms(16);
    frame = frame + 1;
  }

  g_shutdown = 1;
  stop_loader_thread();
  teardown_memory();

  tracy_message_literal(cstr("Tracy demo finished"));
  println(cstr("Done. Inspect Tracy for Frame/Simulation/RenderPrep zones and AssetLoader thread."));
  return 0;
}
