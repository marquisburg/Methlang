import "std/io";
function check(data: int32*, len: int32) -> int32 {
  var i: int32 = 1;
  while (i < len) {
    if (data[i] < data[i-1]) { return i; }
    i = i + 1;
  }
  return 0;
}
function main() -> int32 {
  var d: int32[4];
  d[0] = -266; d[1] = -246; d[2] = -136; d[3] = 5;   // strictly increasing
  print_int((int64)check(&d[0], 4)); println(cstr(""));  // expect 0 (sorted)
  return 0;
}
