import "std/mem";
function tA(b: cstring, i: int64) -> int64 {
  var v: int64 = (int64)(uint8)b[i];
  b[i] = (uint8)1;
  return 1;
}
function tB(b: cstring, i: int64) -> int64 {
  var v: int64 = (int64)(uint8)b[i];
  return v;
}
function main() -> int32 {
  var b: cstring = malloc(16);
  memset(b, 0, 16);
  var a: int64 = tA(b, 1);
  var c: int64 = tB(b, 1);
  free(b);
  return (int32)(a + c);
}
