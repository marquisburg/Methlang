function prefix_sum {
     0: nop
     1: local @sum : int64
     2: assign @sum <- 0
     3: local @i : int64
     4: assign @i <- 0
     5: label ir_while_1
     6: binary %t0 = @i < @n
     7: branch_zero %t0 -> ir_while_end_2
     8: binary %t1 = @i << 2
     9: binary %t2 = @src + %t1
    10: load %t3 <- *%t2 [4]
    11: cast %t4 = (int64)%t3
    12: binary @sum = @sum + %t4
    13: nop
    14: cast %t6 = (int32)@sum
    15: assign %t7 <- %t1
    16: binary %t8 = @dst + %t7
    17: store *%t8 <- %t6 [4]
    18: binary @i = @i + 1
    19: nop
    20: jump ir_while_1
    21: label ir_while_end_2
    22: binary %t10 = @n - 1
    23: binary %t11 = %t10 << 2
    24: binary %t12 = @dst + %t11
    25: load %t13 <- *%t12 [4]
    26: cast %t14 = (int64)%t13
    27: binary %t15 = @sum + %t14
    28: nop
    29: nop
    30: nop
    31: nop
    32: nop
    33: return %t15
}

