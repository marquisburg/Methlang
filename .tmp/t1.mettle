import "std/io";
import "std/mem";
function main() -> int32 {
  var buf_size: int64 = 262144;
  var b: cstring = malloc(buf_size);
  memset(b, 0, buf_size);
  var i: int64 = 0;
  while (i < buf_size) {
    var v: int64 = (int64)(uint8)b[i];
    b[i] = (uint8)(v + 1);
    i = i + 4096;
  }
  println(cstr("ok"));
  free(b);
  return 0;
}
