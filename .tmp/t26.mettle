import "std/mem";
function bump_int(b: cstring, i: int64) -> int64 {
  var p: int32* = (int32*)(b + i * 1);
  var v: int32 = *p;
  *p = v + 1;
  return (int64)v;
}
function main() -> int32 {
  var b: cstring = malloc(16);
  memset(b, 0, 16);
  var r: int64 = bump_int(b, 1);
  free(b);
  return (int32)r;
}
