import "std/mem";
function rd(b: cstring, i: int64) -> int64 { return (int64)(uint8)b[i]; }
function wr(b: cstring, i: int64) -> int32 { b[i] = (uint8)1; return 0; }
function main() -> int32 {
  var b: cstring = malloc(16);
  memset(b, 0, 16);
  var v: int64 = rd(b, 1);
  wr(b, 1);
  free(b);
  return (int32)v;
}
