import "std/io";
import "std/mem";

function main() -> int32 {
  var buf_size: int64 = 262144;
  var b: cstring = malloc(buf_size);
  if (b == 0) {
    return 1;
  }
  memset(b, 0, buf_size);

  var i: int64 = 0;
  while (i < buf_size) {
    var v: int64 = (int64)(uint8)b[i];
    b[i] = (uint8)(v + 1);
    i = i + 8192;
  }

  println(cstr("mod done"));
  free(b);
  return 0;
}
