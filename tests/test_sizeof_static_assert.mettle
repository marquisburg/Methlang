struct BudgetedEntity {
  hot_ptr: int64;
  cold_ptr: int64;
  id: int32;
  flags: int32;
}

static_assert(sizeof(BudgetedEntity) <= 24);
static_assert(sizeof(int64) == 8);

function scene_row_bytes() -> int64 {
  return sizeof(BudgetedEntity);
}

function main() -> int32 {
  if (scene_row_bytes() == 24) {
    return 0;
  }
  return 1;
}
