struct Pair<A, B> {
    first: A;
    second: B;
}

function make_pair<T>(a: T, b: T) -> Pair<T, T> {
    var p: Pair<T, T>;
    p.first = a;
    p.second = b;
    return p;
}

function main() -> int32 {
    var p: Pair<int32, int32> = make_pair<int32>(10, 20);
    return p.first + p.second;
}
