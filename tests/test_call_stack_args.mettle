export function sink6(a: int64, b: int64, c: int64, d: int64, e: int64, outp: int64*) -> int64 {
  if (outp != 0) {
    outp[0] = a + b + c + d + e;
  }
  return 77;
}

export function main() -> int32 {
  var outv: int64 = 0;
  var r: int64 = sink6(1,2,3,4,5,(int64*)((int64)(&(outv))));
  if (r != 77) { return 10; }
  if (outv != 15) { return 11; }
  return 1;
}
