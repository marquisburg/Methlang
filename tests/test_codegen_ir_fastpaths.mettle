function fused_mul_add(a: int64, b: int64) -> int64 {
  var sum: int64 = 0;
  sum = sum + a * b;
  return sum + 5;
}

function scheduled_sum8(a: int64, b: int64, c: int64, d: int64, e: int64, f: int64, g: int64, h: int64) -> int64 {
  return a + b + c + d + e + f + g + h;
}

function is_twelve(value: int64) -> int32 {
  if (value == 12) {
    return 1;
  }
  return 0;
}

function shift_left(value: int64) -> int64 {
  return value << 2;
}

function scale_by_eight(value: int64) -> int64 {
  return value * 8;
}

function zero_const() -> int64 {
  return 0;
}

var global_mask_target: uint64 = 0x524F525245;

function masked_global_compare(value: uint64) -> int32 {
  if ((value & 0xFFFFFFFFFF) == global_mask_target) {
    return 1;
  }
  return 0;
}

function even_branch(value: int64) -> int32 {
  if ((value & 1) == 0) {
    return 1;
  }
  return 0;
}

function main() -> int32 {
  if (is_twelve(fused_mul_add(7, 1)) == 0) {
    return 1;
  }
  if (scheduled_sum8(1, 2, 3, 4, 5, 6, 7, 8) != 36) {
    return 2;
  }
  if (shift_left(5) != 20) {
    return 3;
  }
  if (scale_by_eight(6) != 48) {
    return 6;
  }
  if (zero_const() != 0) {
    return 7;
  }
  if (masked_global_compare(0x12524F525245) != 1) {
    return 8;
  }
  if (masked_global_compare(0x994F525244) != 0) {
    return 9;
  }
  if (even_branch(42) == 0) {
    return 4;
  }
  if (even_branch(43) != 0) {
    return 5;
  }
  return 0;
}
