function read_ptr(p: int32*) -> int64 {
  return (int64)*p;
}

function main() -> int32 {
  var values: int32[3];
  values[0] = 5;
  values[1] = -7;
  values[2] = -1000;

  if (read_ptr(&values[1]) != -7) {
    return 1;
  }

  var loaded: int32 = *(&values[2]);
  var widened: int64 = loaded;
  if (widened != -1000) {
    return 2;
  }

  return 0;
}
