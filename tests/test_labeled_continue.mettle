function main() -> int32 {
  var count: int32 = 0;
  outer: for (var i: int32 = 0; i < 5; i += 1) {
    for (var j: int32 = 0; j < 5; j += 1) {
      if (j == 2) {
        continue outer;
      }
      count += 1;
    }
  }
  // Inner only runs for j=0 and j=1 before skipping; 5 outer iterations * 2 = 10.
  return count;
}
