// Clamp-copy should fuse by shape, not benchmark-specific symbol names.

function narrow(x: int32, floor_bound: int32, ceiling_bound: int32) -> int32 {
  if (x < floor_bound) {
    return floor_bound;
  }
  if (x > ceiling_bound) {
    return ceiling_bound;
  }
  return x;
}

function bounded_copy(input_buf: int32*, output_buf: int32*, count: int64) -> int64 {
  var acc: int64 = 0;
  var idx: int64 = 0;
  while (idx < count) {
    var item: int32 = narrow(input_buf[idx], -90, 90);
    output_buf[idx] = item;
    acc = acc + (int64)item;
    idx = idx + 1;
  }
  return acc;
}

function main() -> int32 {
  var src: int32[8];
  var dst: int32[8];
  src[0] = -200;
  src[1] = -100;
  src[2] = -50;
  src[3] = 0;
  src[4] = 50;
  src[5] = 100;
  src[6] = 150;
  src[7] = 200;

  var total: int64 = bounded_copy(&src[0], &dst[0], 8);
  if (total != 90) {
    return 2;
  }
  if (dst[0] != -90 || dst[7] != 90) {
    return 3;
  }
  return 0;
}
