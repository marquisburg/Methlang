function cold_path() -> int32 {
  return 9;
}

function main() -> int32 {
  var folded: int32 = 6 * 7;
  var result: int32 = folded;
  var same: int32 = result;

  // same-operand identities should fold to constants/assigns
  result = same - same;
  result = result + 42;
  var bits: int32 = folded ^ folded;
  result = result + bits;
  var bool_sink: int32 = same && 0;
  result = result + bool_sink;
  bool_sink = 1 || same;
  result = result + bool_sink;
  result = result - 1;

  if (0) {
    result = cold_path();
  }

  // Branch with equal operands should simplify away.
  if (same == same) {
    result = result + 0;
  }

  if (1) {
    result = result + 0;
  }

  return result;
}
