function read_u32_le(b: uint8*, off: int32) -> uint32 {
  return (uint32)b[off] | ((uint32)b[off + 1] << 8) | ((uint32)b[off + 2] << 16) | ((uint32)b[off + 3] << 24);
}

function write_u32_le(b: uint8*, off: int32, v: uint32) {
  b[off] = (uint8)(v & 255);
  b[off + 1] = (uint8)((v >> 8) & 255);
  b[off + 2] = (uint8)((v >> 16) & 255);
  b[off + 3] = (uint8)((v >> 24) & 255);
}

function page_checksum(data: cstring, size: int32) -> uint32 {
  var hash: uint32 = 2166136261;
  var i: int32 = 0;
  while (i < size) {
    hash = hash ^ (uint32)(uint8)data[i];
    hash = hash * 16777619;
    i = i + 1;
  }
  return hash;
}

function main() -> int32 {
  var buf: uint8[4096];
  var i: int32 = 0;
  while (i < 4096) {
    buf[i] = (uint8)(i & 255);
    i = i + 1;
  }
  write_u32_le((uint8*)(&buf[0]), 20, 0);
  var computed: uint32 = page_checksum((cstring)(&buf[0]), 4096 - 32);
  write_u32_le((uint8*)(&buf[0]), 20, computed);
  var stored: uint32 = read_u32_le((uint8*)(&buf[0]), 20);
  var from_write: uint32 = 0;
  write_u32_le((uint8*)(&buf[0]), 24, computed);
  from_write = read_u32_le((uint8*)(&buf[0]), 24);

  if (stored != computed) {
    return 1;
  }
  if (computed != from_write) {
    return 2;
  }
  if (stored != from_write) {
    return 3;
  }
  return 0;
}
