var N: int32 = 32;

function fill_matrix(m: int32*, seed: int32) {
  var row: int32 = 0;
  var row_base: int64 = 0;
  while (row < N) {
    var col: int32 = 0;
    var idx: int64 = row_base;
    while (col < N) {
      m[idx] = (row * 131 + col * 17 + seed) % 251;
      idx = idx + 1;
      col = col + 1;
    }
    row_base = row_base + (int64)N;
    row = row + 1;
  }
}

function matmul(a: int32*, b: int32*, c: int32*) {
  var row: int32 = 0;
  var row_base: int64 = 0;
  while (row < N) {
    var col: int32 = 0;
    while (col < N) {
      var sum0: int32 = 0;
      var sum1: int32 = 0;
      var sum2: int32 = 0;
      var sum3: int32 = 0;
      var a_idx: int64 = row_base;
      var b_idx: int64 = (int64)col;
      var k: int32 = 0;
      while (k < N) {
        var av: int32 = a[a_idx];
        sum0 = sum0 + av * b[b_idx];
        sum1 = sum1 + av * b[b_idx + 1];
        sum2 = sum2 + av * b[b_idx + 2];
        sum3 = sum3 + av * b[b_idx + 3];
        a_idx = a_idx + 1;
        b_idx = b_idx + (int64)N;
        k = k + 1;
      }
      var c_idx: int64 = row_base + (int64)col;
      c[c_idx] = sum0;
      c[c_idx + 1] = sum1;
      c[c_idx + 2] = sum2;
      c[c_idx + 3] = sum3;
      col = col + 4;
    }
    row_base = row_base + (int64)N;
    row = row + 1;
  }
}

function trace_matrix(m: int32*) -> int64 {
  var sum: int64 = 0;
  var i: int32 = 0;
  var idx: int64 = 0;
  while (i < N) {
    sum = sum + (int64)m[idx];
    idx = idx + (int64)N + 1;
    i = i + 1;
  }
  return sum;
}

function main() -> int32 {
  var a: int32[1024];
  var b: int32[1024];
  var c: int32[1024];

  fill_matrix(&a[0], 3);
  fill_matrix(&b[0], 7);
  matmul(&a[0], &b[0], &c[0]);
  if (trace_matrix(&c[0]) != 15813861) {
    return 1;
  }
  return 0;
}
