// Regression: db_pread + db[0].data_fp + inline page_init_buf in the same function
// must not miscompile `if (n <= 0)` on the binary backend.
import "db_types";
import "db_page";
import "db_io";
import "std/mem";
import "std/io";

export function load_slot(db: Db*) -> int32 {
  var idx: int32 = 0;
  var n: int64 = db_pread(db[0].data_fp, &db[0].cache[idx].data[0], 4096, 0);
  if (n <= 0) {
    page_init_buf(&db[0].cache[idx].data[0], 0, 2);
  }
  return 0;
}

export function main(argc: int32, argv: cstring*) -> int32 {
  if (argc < 2) { return 1; }
  var db: Db* = new Db;
  db[0].data_fp = db_open_file(argv[1], 1);
  if (db[0].data_fp == 0) { return 2; }
  if (load_slot(db) != 0) { return 3; }
  println("ok");
  db_close_file(db[0].data_fp);
  free((cstring)db);
  return 0;
}
