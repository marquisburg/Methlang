import "std/io";

function append(dst: cstring, dst_cap: int32, pos: int32, src: cstring) -> int32 {
  if (dst == 0 || src == 0) {
    return pos;
  }
  var j: int32 = pos;
  var k: int32 = 0;
  while (j + 1 < dst_cap) {
    var ch: uint8 = (uint8)(src[k]);
    if (ch == (uint8)0) {
      return j;
    }
    dst[j] = ch;
    j = j + 1;
    k = k + 1;
  }
  return j;
}

function main() -> int32 {
  var buf: uint8[128];
  var out: cstring = (cstring)((int64)(&(buf[0])));
  var p: int32 = append(out, 128, 0, cstr("Project: "));
  p = append(out, 128, p, cstr("Untitled"));
  p = append(out, 128, p, cstr("   Root: "));
  p = append(out, 128, p, cstr("G:\\Projects\\Mettle\\examples"));
  out[p] = 0;
  println(out);
  return 0;
}
