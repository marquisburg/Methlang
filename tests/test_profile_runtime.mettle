function helper(n: int64) -> int64 {
  var acc: int64 = (int64)0;
  for (var i: int64 = (int64)0; i < n; i = i + (int64)1) {
    acc = acc + i;
  }
  return acc;
}

function work() -> int64 {
  var total: int64 = (int64)0;
  for (var j: int64 = (int64)0; j < (int64)10; j = j + (int64)1) {
    total = total + helper((int64)50);
  }
  return total;
}

function main() -> int32 {
  var _unused: int64 = work();
  return 0;
}
