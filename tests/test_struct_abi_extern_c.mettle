// Struct ABI C boundary: Mettle calls C functions that pass/return
// Microsoft x64 indirect structs by value.
import "std/conv";
import "std/io";

struct ThreeI32 {
  a: int32;
  b: int32;
  c: int32;
}

struct Odd3 {
  a: uint8;
  b: uint8;
  c: uint8;
}

extern function c_sum_three(t: ThreeI32) -> int32 = "mettle_struct_abi_c_sum_three";
extern function c_make_three(a: int32, b: int32, c: int32) -> ThreeI32 = "mettle_struct_abi_c_make_three";
extern function c_sum_odd3(o: Odd3) -> int32 = "mettle_struct_abi_c_sum_odd3";
extern function c_make_odd3(a: uint8, b: uint8, c: uint8) -> Odd3 = "mettle_struct_abi_c_make_odd3";

function write_s(s: cstring) {
  if (s != 0) {
    fputs(s, get_stdout());
  }
}

function write_i64(v: int64) {
  var buf: uint8[32];
  int_to_dec((cstring)((int64)(&(buf[0]))), v);
  write_s((cstring)((int64)(&(buf[0]))));
}

function line_i64(label: cstring, v: int64) {
  write_s(label);
  write_s(cstr(" "));
  write_i64(v);
  write_s(cstr("\n"));
}

function make_three(a: int32, b: int32, c: int32) -> ThreeI32 {
  var t: ThreeI32;
  t.a = a;
  t.b = b;
  t.c = c;
  return t;
}

function main() -> int32 {
  write_s(cstr("struct abi extern c\n"));

  var t: ThreeI32 = make_three(11, 22, 33);
  line_i64(cstr("c_sum_three"), (int64)c_sum_three(t));

  var u: ThreeI32 = c_make_three(3, 4, 5);
  line_i64(cstr("c_make_three_sum"), (int64)(u.a + u.b + u.c));

  var o: Odd3 = c_make_odd3(7, 8, 9);
  line_i64(cstr("c_make_odd3_sum"), (int64)c_sum_odd3(o));

  return 0;
}
