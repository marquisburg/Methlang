import "../engine/engine_vk_shaders";
import "../engine/engine_vulkan";
import "std/io";

// Stack footprint clone of vk_context_create_pipeline without Vulkan calls.
function pipeline_stack_footprint() -> int32 {
  var vbuf: uint32[400];
  var fbuf: uint32[160];
  vk_spv_scene_vert_fill((uint32*)((int64)(&(vbuf[0]))));
  vk_spv_scene_frag_fill((uint32*)((int64)(&(fbuf[0]))));

  var stages: VkPipelineShaderStageCreateInfo[2];
  stages[0].s_type = VK_ST_PIPELINE_SHADER_STAGE_CREATE_INFO();
  stages[0].module_handle = (int64)111;
  stages[1].module_handle = (int64)222;

  var vbind: VkVertexInputBindingDescription;
  var vattr: VkVertexInputAttributeDescription[2];
  var vis: VkPipelineVertexInputStateCreateInfo;
  var ias: VkPipelineInputAssemblyStateCreateInfo;
  var vps: VkPipelineViewportStateCreateInfo;
  var rs: VkPipelineRasterizationStateCreateInfo;
  var ms: VkPipelineMultisampleStateCreateInfo;
  var cba: VkPipelineColorBlendAttachmentState;
  var cbs: VkPipelineColorBlendStateCreateInfo;
  var dss: VkPipelineDepthStencilStateCreateInfo;
  var dyn_states: uint32[2];
  var dyns: VkPipelineDynamicStateCreateInfo;
  var pcr: VkPushConstantRange;
  var plci: VkPipelineLayoutCreateInfo;
  var gpci: VkGraphicsPipelineCreateInfo;
  gpci.s_type = VK_ST_GRAPHICS_PIPELINE_CREATE_INFO();
  gpci.base_pipeline_index = -1;
  if (stages[1].module_handle != (int64)222) {
    return 0;
  }
  if (vbuf[0] == (uint32)0) {
    return 0;
  }
  return 1;
}

export function main() -> int32 {
  return pipeline_stack_footprint();
}
