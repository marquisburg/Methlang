// Correctness test for the general reduction-unrolling vectorizer.
//
// None of these are the sum_squares benchmark; they exercise the pass on
// distinct pure reductions to show it generalizes (different EXPR(i),
// different bounds incl. non-multiple-of-unroll trip counts, an affine form,
// and a constant-only body). Each printed value has a closed form so the
// harness can assert exact results.

import "std/io";

// sum_{i=1..n} i  = n(n+1)/2.  n=1000 -> 500500. Trip count 1000 (mult of 4).
function sum_linear(n: int64) -> int64 {
  var s: int64 = 0;
  var i: int64 = 1;
  while (i <= n) {
    s = s + i;
    i = i + 1;
  }
  return s;
}

// sum_{i=1..n} (3*i + 7) = 3*n(n+1)/2 + 7n.  n=1003 (NOT a multiple of 4, so
// the scalar remainder tail must run). n=1003 -> 3*503506 + 7021 = 1517539.
function sum_affine(n: int64) -> int64 {
  var s: int64 = 0;
  var i: int64 = 1;
  while (i <= n) {
    s = s + (3 * i + 7);
    i = i + 1;
  }
  return s;
}

// sum_{i=0..n-1} of a constant (exclusive bound, '<'): 1 added n times = n.
// n=777 (not a multiple of 4).
function count_to(n: int64) -> int64 {
  var s: int64 = 0;
  var i: int64 = 0;
  while (i < n) {
    s = s + 1;
    i = i + 1;
  }
  return s;
}

function main() -> int32 {
  print(cstr("lin="));
  println_int(sum_linear(1000));      // 500500
  print(cstr("aff="));
  println_int(sum_affine(1003));      // 1517539
  print(cstr("cnt="));
  println_int(count_to(777));         // 777
  return 0;
}
