import "../engine/engine_scene";
import "../engine/engine_scene_io";
import "../engine/engine_mesh";
import "std/io";

function main() -> int32 {
  var sc: Scene* = scene_create(8);
  if (sc == 0) {
    return 1;
  }
  var meshes: MeshStore* = mesh_store_create(8);
  if (meshes == 0) {
    scene_destroy(sc);
    return 2;
  }
  scene_seed_default(sc);
  scene_io_save(cstr(".tmp/test_direct_object_scene_save_names.mscene"), sc, cstr(""));
  scene_clear(sc);
  scene_io_load(cstr(".tmp/test_direct_object_scene_save_names.mscene"), sc, meshes, cstr(""));
  var e: Entity* = scene_row(sc, 0);
  if (e == 0) {
    mesh_store_destroy(meshes);
    scene_destroy(sc);
    return 3;
  }
  println(scene_entity_name(e));
  mesh_store_destroy(meshes);
  scene_destroy(sc);
  return 0;
}
