enum Option<T> {
    Some(T),
    None
}

function unwrap_int32(o: Option<int32>) -> int32 {
    match (o) {
        case Some(v): {
            return v;
        }
        default: {
            return -1;
        }
    }
}

function main() -> int32 {
    var a: Option<int32> = Some(42);
    return unwrap_int32(a);
}
