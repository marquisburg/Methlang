// Inclusive prefix sum should fuse to prefix_sum_i32 after inlining.

function prefix_sum(src: int32*, dst: int32*, n: int64) -> int64 {
  var sum: int64 = 0;
  var i: int64 = 0;
  while (i < n) {
    sum = sum + (int64)src[i];
    dst[i] = (int32)sum;
    i = i + 1;
  }
  return sum + (int64)dst[n - 1];
}

function main() -> int32 {
  var src: int32[8];
  var dst: int32[8];
  var n: int64 = 8;

  var i: int64 = 0;
  while (i < n) {
    src[i] = (int32)(i + 1);
    i = i + 1;
  }

  var total: int64 = prefix_sum(&src[0], &dst[0], n);
  if (total != 72) {
    return 2;
  }
  if (dst[7] != 36) {
    return 3;
  }
  return 0;
}
