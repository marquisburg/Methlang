// Reproduce stack cookie failure: large locals + nested calls (no Vulkan).
import "../engine/engine_vk_shaders";
import "../engine/engine_vulkan";

function noop_call(ctx: int64, info: VkGraphicsPipelineCreateInfo*, out_pipe: int64*) -> int32 {
  if (ctx == 0 || info == 0 || out_pipe == 0) {
    return 0;
  }
  out_pipe[0] = (int64)1;
  return 0;
}

function pipeline_stack_with_calls(ctx: VkContext*) -> int32 {
  if (ctx == 0 || ctx->device == 0 || ctx->render_pass == 0) {
    return 0;
  }

  var vbuf: uint32[400];
  var fbuf: uint32[160];
  vk_spv_scene_vert_fill((uint32*)((int64)(&(vbuf[0]))));
  vk_spv_scene_frag_fill((uint32*)((int64)(&(fbuf[0]))));

  var stages: VkPipelineShaderStageCreateInfo[2];
  stages[0].s_type = VK_ST_PIPELINE_SHADER_STAGE_CREATE_INFO();
  stages[0].p_next = (int64)0;
  stages[0].flags = (uint32)0;
  stages[0].stage = (uint32)1;
  stages[0].module_handle = (int64)1;
  stages[0].p_name = (int64)cstr("main");
  stages[0].p_specialization_info = (int64)0;
  stages[1].s_type = VK_ST_PIPELINE_SHADER_STAGE_CREATE_INFO();
  stages[1].p_next = (int64)0;
  stages[1].flags = (uint32)0;
  stages[1].stage = (uint32)16;
  stages[1].module_handle = (int64)2;
  stages[1].p_name = (int64)cstr("main");
  stages[1].p_specialization_info = (int64)0;
  var stages_base: int64 = (int64)(&(stages[0]));

  var vbind: VkVertexInputBindingDescription;
  vbind.binding = (uint32)0;
  vbind.stride = (uint32)24;
  vbind.input_rate = (uint32)0;
  var vattr: VkVertexInputAttributeDescription[2];
  vattr[0].location = (uint32)0;
  vattr[0].binding = (uint32)0;
  vattr[0].format = (uint32)106;
  vattr[0].offset = (uint32)0;
  vattr[1].location = (uint32)1;
  vattr[1].binding = (uint32)0;
  vattr[1].format = (uint32)106;
  vattr[1].offset = (uint32)12;

  var vis: VkPipelineVertexInputStateCreateInfo;
  vis.s_type = VK_ST_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO();
  vis.p_next = (int64)0;
  vis.flags = (uint32)0;
  vis.vertex_binding_description_count = (uint32)1;
  vis.p_vertex_binding_descriptions = (int64)(&vbind);
  vis.vertex_attribute_description_count = (uint32)2;
  vis.p_vertex_attribute_descriptions = (int64)((int64)(&(vattr[0])));

  var ias: VkPipelineInputAssemblyStateCreateInfo;
  ias.s_type = VK_ST_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO();
  ias.p_next = (int64)0;
  ias.flags = (uint32)0;
  ias.topology = (uint32)1;
  ias.primitive_restart_enable = (uint32)0;

  var vps: VkPipelineViewportStateCreateInfo;
  vps.s_type = VK_ST_PIPELINE_VIEWPORT_STATE_CREATE_INFO();
  vps.p_next = (int64)0;
  vps.flags = (uint32)0;
  vps.viewport_count = (uint32)1;
  vps.p_viewports = (int64)0;
  vps.scissor_count = (uint32)1;
  vps.p_scissors = (int64)0;

  var rs: VkPipelineRasterizationStateCreateInfo;
  rs.s_type = VK_ST_PIPELINE_RASTERIZATION_STATE_CREATE_INFO();
  rs.p_next = (int64)0;
  rs.flags = (uint32)0;
  rs.depth_clamp_enable = (uint32)0;
  rs.rasterizer_discard_enable = (uint32)0;
  rs.polygon_mode = (uint32)0;
  rs.cull_mode = (uint32)0;
  rs.front_face = (uint32)1;
  rs.depth_bias_enable = (uint32)0;
  rs.depth_bias_constant_factor = (float32)0.0;
  rs.depth_bias_clamp = (float32)0.0;
  rs.depth_bias_slope_factor = (float32)0.0;
  rs.line_width = (float32)1.0;

  var ms: VkPipelineMultisampleStateCreateInfo;
  ms.s_type = VK_ST_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO();
  ms.p_next = (int64)0;
  ms.flags = (uint32)0;
  ms.rasterization_samples = (uint32)1;
  ms.sample_shading_enable = (uint32)0;
  ms.min_sample_shading = (float32)0.0;
  ms.p_sample_mask = (int64)0;
  ms.alpha_to_coverage_enable = (uint32)0;
  ms.alpha_to_one_enable = (uint32)0;

  var cba: VkPipelineColorBlendAttachmentState;
  cba.blend_enable = (uint32)0;
  cba.src_color_blend_factor = (uint32)1;
  cba.dst_color_blend_factor = (uint32)0;
  cba.color_blend_op = (uint32)0;
  cba.src_alpha_blend_factor = (uint32)1;
  cba.dst_alpha_blend_factor = (uint32)0;
  cba.alpha_blend_op = (uint32)0;
  cba.color_write_mask = (uint32)15;

  var cbs: VkPipelineColorBlendStateCreateInfo;
  cbs.s_type = VK_ST_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO();
  cbs.p_next = (int64)0;
  cbs.flags = (uint32)0;
  cbs.logic_op_enable = (uint32)0;
  cbs.logic_op = (uint32)0;
  cbs.attachment_count = (uint32)1;
  cbs.p_attachments = (int64)(&cba);
  cbs.blend_constant0 = (float32)0.0;
  cbs.blend_constant1 = (float32)0.0;
  cbs.blend_constant2 = (float32)0.0;
  cbs.blend_constant3 = (float32)0.0;

  var dss: VkPipelineDepthStencilStateCreateInfo;
  dss.s_type = (uint32)25;
  dss.p_next = (int64)0;
  dss.flags = (uint32)0;
  dss.depth_test_enable = (uint32)1;
  dss.depth_write_enable = (uint32)0;
  dss.depth_compare_op = (uint32)3;
  dss.depth_bounds_test_enable = (uint32)0;
  dss.stencil_test_enable = (uint32)0;
  dss.front_fail_op = (uint32)0;
  dss.front_pass_op = (uint32)0;
  dss.front_depth_fail_op = (uint32)0;
  dss.front_compare_op = (uint32)0;
  dss.front_compare_mask = (uint32)0;
  dss.front_write_mask = (uint32)0;
  dss.front_reference = (uint32)0;
  dss.back_fail_op = (uint32)0;
  dss.back_pass_op = (uint32)0;
  dss.back_depth_fail_op = (uint32)0;
  dss.back_compare_op = (uint32)0;
  dss.back_compare_mask = (uint32)0;
  dss.back_write_mask = (uint32)0;
  dss.back_reference = (uint32)0;
  dss.min_depth_bounds = (float32)0.0;
  dss.max_depth_bounds = (float32)1.0;

  var dyn_states: uint32[2];
  dyn_states[0] = (uint32)0;
  dyn_states[1] = (uint32)1;
  var dyns: VkPipelineDynamicStateCreateInfo;
  dyns.s_type = (uint32)27;
  dyns.p_next = (int64)0;
  dyns.flags = (uint32)0;
  dyns.dynamic_state_count = (uint32)2;
  dyns.p_dynamic_states = (int64)((int64)(&(dyn_states[0])));

  var pcr: VkPushConstantRange;
  pcr.stage_flags = (uint32)1;
  pcr.offset = (uint32)0;
  pcr.size = (uint32)64;

  var plci: VkPipelineLayoutCreateInfo;
  plci.s_type = VK_ST_PIPELINE_LAYOUT_CREATE_INFO();
  plci.p_next = (int64)0;
  plci.flags = (uint32)0;
  plci.set_layout_count = (uint32)0;
  plci.p_set_layouts = (int64)0;
  plci.push_constant_range_count = (uint32)1;
  plci.p_push_constant_ranges = (int64)(&pcr);

  var gpci: VkGraphicsPipelineCreateInfo;
  gpci.s_type = VK_ST_GRAPHICS_PIPELINE_CREATE_INFO();
  gpci.p_next = (int64)0;
  gpci.flags = (uint32)0;
  gpci.stage_count = (uint32)2;
  gpci.p_stages = stages_base;
  gpci.p_vertex_input_state = (int64)(&vis);
  gpci.p_input_assembly_state = (int64)(&ias);
  gpci.p_tessellation_state = (int64)0;
  gpci.p_viewport_state = (int64)(&vps);
  gpci.p_rasterization_state = (int64)(&rs);
  gpci.p_multisample_state = (int64)(&ms);
  gpci.p_depth_stencil_state = (int64)(&dss);
  gpci.p_color_blend_state = (int64)(&cbs);
  gpci.p_dynamic_state = (int64)(&dyns);
  gpci.layout = (int64)1;
  gpci.render_pass = ctx->render_pass;
  gpci.subpass = (uint32)0;
  gpci.base_pipeline_handle = (int64)0;
  gpci.base_pipeline_index = -1;

  var pipe: int64 = 0;
  var solid_pipe: int64 = 0;
  var i: int32 = 0;
  while (i < 8) {
    noop_call(ctx->device, &gpci, &pipe);
    ias.topology = (uint32)3;
    dss.depth_write_enable = (uint32)1;
    noop_call(ctx->device, &gpci, &solid_pipe);
    i = i + 1;
  }

  if (stages[1].module_handle != (int64)2) {
    return 0;
  }
  if (vbuf[302] == (uint32)0) {
    return 0;
  }
  return 1;
}

export function main() -> int32 {
  var raw: uint8[1024];
  var ctx: VkContext* = (VkContext*)((int64)(&(raw[0])));
  ctx->device = (int64)1;
  ctx->render_pass = (int64)2;
  return pipeline_stack_with_calls(ctx);
}
