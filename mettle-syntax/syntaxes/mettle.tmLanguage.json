{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mettle",
  "scopeName": "source.mettle",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#asm-block" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mettle",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mettle",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mettle",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mettle",
              "match": "\\\\[\\\\\"nrt0]"
            },
            {
              "name": "invalid.illegal.escape.mettle",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "constant.character.escape.mettle",
          "match": "'\\\\[\\\\'nrt0]'"
        },
        {
          "name": "constant.character.mettle",
          "match": "'[^\\\\'\\r\\n]'"
        },
        {
          "name": "invalid.illegal.character.mettle",
          "match": "'(?:\\\\.|[^'\\r\\n]){2,}'"
        }
      ]
    },
    "asm-block": {
      "patterns": [
        {
          "name": "meta.embedded.block.asm.mettle",
          "begin": "\\b(asm)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "keyword.other.asm.mettle" },
            "2": { "name": "punctuation.definition.block.begin.mettle" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.block.end.mettle" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#asm" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "asm": {
      "patterns": [
        {
          "name": "keyword.mnemonic.x86.mettle",
          "match": "\\b(mov|add|sub|mul|imul|div|idiv|inc|dec|cmp|test|jmp|je|jne|jl|jle|jg|jge|ja|jae|jb|jbe|call|ret|push|pop|lea|nop|int|syscall|xor|and|or|shl|shr|sal|sar)\\b"
        },
        {
          "name": "variable.language.register.x86.mettle",
          "match": "\\b([re]?[abcd]x|[re]?[sd]i|[re]?[sb]p|r(?:[8-9]|1[0-5])[bwd]?|[abcd][lh]|xmm[0-9]+|ymm[0-9]+|zmm[0-9]+)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.mettle",
          "match": "\\b(export\\s+)?(extern\\s+)?(function|fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.export.mettle" },
            "2": { "name": "keyword.declaration.extern.mettle" },
            "3": { "name": "keyword.declaration.function.mettle" },
            "4": { "name": "entity.name.function.mettle" }
          }
        },
        {
          "name": "meta.type.declaration.mettle",
          "match": "\\b(export\\s+)?(struct|enum|trait|impl)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.export.mettle" },
            "2": { "name": "keyword.declaration.type.mettle" },
            "3": { "name": "entity.name.type.mettle" }
          }
        },
        {
          "name": "meta.method.mettle",
          "match": "\\b(method)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.method.mettle" },
            "2": { "name": "entity.name.function.method.mettle" }
          }
        },
        {
          "name": "meta.import.mettle",
          "match": "\\b(import|import_str)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.import.mettle" },
            "2": { "name": "string.quoted.double.import.mettle" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mettle",
          "match": "\\b(if|else|while|for|switch|match|case|default|break|continue|return|defer|errdefer)\\b"
        },
        {
          "name": "keyword.declaration.mettle",
          "match": "\\b(import|import_str|extern|export|var|function|fn|struct|enum|method|trait|impl|where)\\b"
        },
        {
          "name": "keyword.operator.word.mettle",
          "match": "\\b(sizeof|static_assert)\\b"
        },
        {
          "name": "keyword.other.mettle",
          "match": "\\b(asm|this|new|Self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.mettle",
          "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|float32|float64|string|cstring|bool|void)\\b"
        },
        {
          "name": "storage.type.function.mettle",
          "match": "\\bfn\\b(?=\\s*\\()"
        },
        {
          "name": "support.type.mettle",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*(?:[<*\\[\\{;,\\):]|->|$))"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.mettle",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mettle",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.mettle",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.float.mettle",
          "match": "\\b(?:[0-9]+\\.[0-9]*|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.mettle",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.mettle",
          "match": "<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^="
        },
        {
          "name": "keyword.operator.arrow.mettle",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.mettle",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.mettle",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.mettle",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.assignment.mettle",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.mettle",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.mettle",
          "match": "[:;,.]"
        },
        {
          "name": "punctuation.definition.mettle",
          "match": "[{}\\[\\]()]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.member.mettle",
          "match": "\\.(chars|length)\\b"
        },
        {
          "name": "variable.other.member.mettle",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "support.function.mettle",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "variable.other.mettle",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
