{
  "function": {
    "prefix": "fn",
    "body": [
      "function ${1:name}(${2}) -> ${3:int32} {",
      "  ${0:return 0;}",
      "}"
    ],
    "description": "Function declaration"
  },
  "main": {
    "prefix": "main",
    "body": [
      "function main() -> int32 {",
      "  ${0:return 0;}",
      "}"
    ],
    "description": "Program entry point"
  },
  "extern function": {
    "prefix": "externfn",
    "body": [
      "extern function ${1:name}(${2}) -> ${3:int32} = \"${4:symbol}\";"
    ],
    "description": "Extern function declaration"
  },
  "struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "  ${2:field}: ${3:int32};",
      "}"
    ],
    "description": "Struct declaration"
  },
  "enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "  ${2:Variant}",
      "}"
    ],
    "description": "Enum declaration"
  },
  "match": {
    "prefix": "match",
    "body": [
      "match (${1:value}) {",
      "  case ${2:Variant}: {",
      "    ${0}",
      "  }",
      "  default: {",
      "  }",
      "}"
    ],
    "description": "Match statement"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for (var ${1:i}: int32 = 0; ${1:i} < ${2:count}; ${1:i} += 1) {",
      "  ${0}",
      "}"
    ],
    "description": "For loop"
  },
  "while": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "  ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "defer": {
    "prefix": "defer",
    "body": [
      "defer ${1:cleanup()};"
    ],
    "description": "Defer a cleanup statement"
  },
  "errdefer": {
    "prefix": "errdefer",
    "body": [
      "errdefer ${1:rollback()};"
    ],
    "description": "Defer a cleanup statement for non-zero returns"
  },
  "import": {
    "prefix": "import",
    "body": [
      "import \"${1:std/io}\";"
    ],
    "description": "Import a module"
  },
  "import_str": {
    "prefix": "importstr",
    "body": [
      "var ${1:name}: string = import_str \"${2:path}\";"
    ],
    "description": "Embed a text file as a string"
  },
  "static_assert": {
    "prefix": "staticassert",
    "body": [
      "static_assert(${1:sizeof(Type) <= 8});"
    ],
    "description": "Static assertion"
  },
  "trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "  function ${2:method}(self: Self) -> ${3:Self};",
      "}"
    ],
    "description": "Trait declaration"
  },
  "impl": {
    "prefix": "impl",
    "body": [
      "impl ${1:Trait} for ${2:Type} {",
      "  function ${3:method}(self: Self) -> ${4:Self} {",
      "    ${0:return self;}",
      "  }",
      "}"
    ],
    "description": "Trait implementation"
  }
}
